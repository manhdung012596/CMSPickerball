@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Liên hệ";
}

@section Styles {
    <style>
        .page-header-banner {
            background-color: var(--dark-slate);
            padding: 50px 0;
            color: #ffffff;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            text-align: center;
        }

        .page-title {
            font-size: 36px;
            font-weight: 800;
            margin-bottom: 10px;
        }

        .breadcrumb-custom {
            display: flex;
            justify-content: center;
            gap: 8px;
            font-size: 14px;
            color: #94a3b8;
            font-weight: 500;
        }

        .breadcrumb-custom a {
            color: var(--lime-bright);
            text-decoration: none;
        }

        .section-padding {
            padding: 80px 0;
        }

        /* Contact Details Card */
        .contact-info-card {
            background: #ffffff;
            border-radius: 24px;
            border: 1px solid var(--border-color);
            padding: 40px;
            box-shadow: var(--card-shadow);
            height: 100%;
        }

        .contact-detail-row {
            display: flex;
            align-items: flex-start;
            gap: 20px;
            margin-bottom: 30px;
        }

        .contact-detail-row:last-child {
            margin-bottom: 0;
        }

        .contact-icon-circle {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background-color: rgba(132, 204, 22, 0.12);
            color: var(--lime-green);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            flex-shrink: 0;
            transition: var(--transition-smooth);
        }

        .contact-detail-row:hover .contact-icon-circle {
            background-color: var(--dark-slate);
            color: var(--lime-bright);
            transform: scale(1.05);
        }

        .contact-text-group h5 {
            font-size: 16px;
            font-weight: 700;
            color: var(--dark-slate);
            margin-bottom: 6px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .contact-text-group p {
            font-size: 15px;
            color: #475569;
            margin-bottom: 0;
            line-height: 1.6;
            font-weight: 500;
        }

        /* Message form card */
        .contact-form-card {
            background: #ffffff;
            border-radius: 24px;
            border: 1px solid var(--border-color);
            padding: 40px;
            box-shadow: var(--card-shadow);
        }

        .form-label-contact {
            font-size: 12px;
            font-weight: 700;
            color: #64748b;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
        }

        .form-control-contact {
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 12px 16px;
            font-size: 15px;
            color: var(--dark-blue);
            font-weight: 500;
            transition: var(--transition-smooth);
        }

        .form-control-contact:focus {
            border-color: var(--lime-green);
            box-shadow: 0 0 0 3px rgba(132, 204, 22, 0.15);
            outline: none;
        }

        .btn-submit-contact {
            background: linear-gradient(135deg, var(--lime-green) 0%, #76b813 100%);
            color: #ffffff;
            font-family: 'Outfit', sans-serif;
            font-weight: 700;
            padding: 12px 30px;
            border-radius: 12px;
            border: none;
            box-shadow: 0 4px 15px rgba(132, 204, 22, 0.2);
            transition: var(--transition-smooth);
        }

        .btn-submit-contact:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(132, 204, 22, 0.3);
            color: #ffffff;
            background: var(--dark-slate);
        }

        /* Map styling */
        .map-wrapper {
            margin-top: 50px;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: var(--card-shadow);
            border: 1px solid var(--border-color);
        }
    </style>
}

<!-- PAGE HEADER BANNER -->
<div class="page-header-banner">
    <div class="container">
        <h1 class="page-title">Liên Hệ Với Chúng Tôi</h1>
        <div class="breadcrumb-custom">
            <a href="/Home/Index">Trang chủ</a>
            <span>/</span>
            <span>Liên hệ</span>
        </div>
    </div>
</div>

<!-- MAIN CONTENT -->
<div class="container section-padding">
    <div class="row g-5">
        
        <!-- Left: Contact Details Cards -->
        <div class="col-lg-5">
            <div class="contact-info-card">
                <h3 class="fw-bold mb-4" style="font-family: 'Outfit'; font-size: 26px;">Thông tin liên hệ</h3>
                
                <div class="contact-detail-row">
                    <div class="contact-icon-circle"><i class="fa-solid fa-location-dot"></i></div>
                    <div class="contact-text-group">
                        <h5>Địa chỉ</h5>
                        <p>123 Đường ABC, Phường XYZ, Quận 1, TP. Hồ Chí Minh</p>
                    </div>
                </div>
                
                <div class="contact-detail-row">
                    <div class="contact-icon-circle"><i class="fa-solid fa-phone"></i></div>
                    <div class="contact-text-group">
                        <h5>Điện thoại</h5>
                        <p>090.123.456 (Hotline hỗ trợ 24/7)</p>
                    </div>
                </div>

                <div class="contact-detail-row">
                    <div class="contact-icon-circle"><i class="fa-solid fa-envelope"></i></div>
                    <div class="contact-text-group">
                        <h5>Email</h5>
                        <p>info@pickleballclub.com</p>
                    </div>
                </div>

                <div class="contact-detail-row">
                    <div class="contact-icon-circle"><i class="fa-solid fa-clock"></i></div>
                    <div class="contact-text-group">
                        <h5>Giờ mở cửa</h5>
                        <p>06:00 - 22:00 (Tất cả các ngày trong tuần, kể cả ngày lễ)</p>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Right: Message Sending Form -->
        <div class="col-lg-7">
            <div class="contact-form-card">
                <h3 class="fw-bold mb-4" style="font-family: 'Outfit'; font-size: 26px;">Gửi tin nhắn phản hồi</h3>
                
                <form id="contactForm" onsubmit="submitContactForm(); return false;" class="row g-4">
                    <div class="col-md-6">
                        <label class="form-label-contact">Họ và Tên *</label>
                        <input type="text" class="form-control form-control-contact w-100" id="contactName" required placeholder="Nhập họ và tên..." />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label-contact">Địa chỉ Email *</label>
                        <input type="email" class="form-control form-control-contact w-100" id="contactEmail" required placeholder="Nhập địa chỉ email..." />
                    </div>
                    <div class="col-12">
                        <label class="form-label-contact">Số điện thoại</label>
                        <input type="tel" class="form-control form-control-contact w-100" id="contactPhone" placeholder="Nhập số điện thoại liên lạc..." />
                    </div>
                    <div class="col-12">
                        <label class="form-label-contact">Nội dung tin nhắn *</label>
                        <textarea class="form-control form-control-contact w-100" id="contactMessage" required rows="4" placeholder="Nhập câu hỏi hoặc nội dung bạn cần hỗ trợ..."></textarea>
                    </div>
                    <div class="col-12 text-end">
                        <button type="submit" class="btn-submit-contact"><i class="fa-solid fa-paper-plane me-2"></i>Gửi tin nhắn</button>
                    </div>
                </form>
            </div>
        </div>
        
    </div>
    
    <!-- Map Embed section -->
    <div class="map-wrapper">
        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3919.4243640277344!2d106.69085817573617!3d10.778799989370046!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3919000000000001%3A0x0!2sDistrict%201%20HCMC!5e0!3m2!1sen!2svn!4v1718712345678!5m2!1sen!2svn" width="100%" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
    </div>
</div>

@section Scripts {
    <script>
        function submitContactForm() {
            const name = document.getElementById('contactName').value.trim();
            const email = document.getElementById('contactEmail').value.trim();
            const phone = document.getElementById('contactPhone').value.trim();
            const message = document.getElementById('contactMessage').value.trim();
            
            if (!name || !email || !message) {
                alert('Vui lòng điền các trường bắt buộc (*)');
                return;
            }
            
            alert(`📨 Gửi tin nhắn thành công!\n\nCảm ơn ${name} đã gửi liên hệ. Chúng tôi đã nhận được thông tin phản hồi của bạn và sẽ phản hồi sớm nhất qua email: ${email}.`);
            document.getElementById('contactForm').reset();
        }
    </script>
}
