@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Trang chủ";
}

@section Styles {
    <style>
        /* Hero Section */
        .hero-section {
            background-color: var(--dark-slate);
            background-image: linear-gradient(180deg, var(--dark-slate) 0%, #090d16 100%);
            padding: 100px 0 120px;
            color: #ffffff;
            position: relative;
            overflow: hidden;
        }

        .hero-section::before {
            content: '';
            position: absolute;
            bottom: -50px;
            left: -50px;
            width: 350px;
            height: 350px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(132, 204, 22, 0.12) 0%, transparent 70%);
            z-index: 0;
        }

        .hero-section::after {
            content: '';
            position: absolute;
            top: -100px;
            right: -100px;
            width: 450px;
            height: 450px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(132, 204, 22, 0.08) 0%, transparent 70%);
            z-index: 0;
        }

        .hero-tagline {
            font-size: 15px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: var(--lime-bright);
            margin-bottom: 20px;
            display: inline-block;
        }

        .hero-title {
            font-size: 54px;
            font-weight: 800;
            line-height: 1.15;
            letter-spacing: -1.5px;
            margin-bottom: 25px;
            background: linear-gradient(135deg, #ffffff 60%, #e2e8f0 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero-title span {
            background: linear-gradient(135deg, var(--lime-bright) 0%, #76b813 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: 800;
        }

        .hero-desc {
            font-size: 18px;
            color: #94a3b8;
            margin-bottom: 40px;
            line-height: 1.7;
            max-width: 600px;
        }

        .hero-buttons {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
        }

        .btn-secondary-custom {
            background-color: rgba(255, 255, 255, 0.05);
            color: #ffffff;
            font-weight: 700;
            font-family: 'Outfit', sans-serif;
            padding: 12px 30px;
            border-radius: 12px;
            border: 1px solid rgba(255, 255, 255, 0.15);
            transition: var(--transition-smooth);
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 10px;
        }

        .btn-secondary-custom:hover {
            background-color: rgba(255, 255, 255, 0.1);
            color: var(--lime-bright);
            border-color: var(--lime-bright);
        }

        /* Hero Image with Curved Loops */
        .hero-image-container {
            position: relative;
            z-index: 2;
            width: 100%;
            max-width: 500px;
            margin: 0 auto;
        }

        .hero-img {
            width: 100%;
            border-radius: 30px;
            border: 6px solid rgba(255, 255, 255, 0.05);
            box-shadow: 0 20px 40px rgba(0,0,0,0.3);
            position: relative;
            z-index: 2;
        }

        .hero-image-container::before {
            content: '';
            position: absolute;
            top: -20px;
            left: -20px;
            right: -20px;
            bottom: -20px;
            border-radius: 36px;
            border: 2.5px solid var(--lime-green);
            z-index: 1;
            clip-path: polygon(0 0, 100% 0, 100% 70%, 0 100%);
            transform: rotate(-3deg);
        }

        .hero-image-container::after {
            content: '';
            position: absolute;
            top: -30px;
            left: -30px;
            right: -30px;
            bottom: -30px;
            border-radius: 40px;
            border: 1.5px dashed var(--lime-green);
            z-index: 0;
            opacity: 0.5;
            transform: rotate(5deg);
        }

        /* Stats Banner Grid */
        .stats-banner-wrapper {
            margin-top: -60px;
            position: relative;
            z-index: 10;
        }

        .stats-banner {
            background-color: #ffffff;
            border-radius: 24px;
            padding: 30px 40px;
            box-shadow: 0 15px 40px rgba(15, 23, 42, 0.08);
            border: 1px solid var(--border-color);
        }

        .stat-card {
            text-align: center;
            border-right: 1px solid var(--border-color);
        }

        .stat-card:last-child {
            border-right: none;
        }

        .stat-num {
            font-size: 38px;
            font-weight: 800;
            color: var(--dark-slate);
            margin-bottom: 2px;
            font-family: 'Outfit', sans-serif;
            background: linear-gradient(135deg, var(--dark-slate) 0%, var(--dark-blue) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .stat-lbl {
            font-size: 14px;
            font-weight: 600;
            color: #64748b;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* Sections common styling */
        .section-padding {
            padding: 100px 0;
        }

        .section-title-wrapper {
            margin-bottom: 50px;
            text-align: center;
        }

        .section-tag {
            font-size: 13px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: var(--lime-green);
            margin-bottom: 12px;
            display: inline-block;
        }

        .section-title {
            font-size: 38px;
            font-weight: 800;
            color: var(--dark-slate);
            letter-spacing: -1px;
        }

        /* Showcase Sân của chúng tôi */
        .court-card {
            background: #ffffff;
            border-radius: 20px;
            border: 1px solid var(--border-color);
            overflow: hidden;
            box-shadow: var(--card-shadow);
            transition: var(--transition-smooth);
            height: 100%;
            display: flex;
            flex-direction: column;
        }

        .court-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 35px rgba(15, 23, 42, 0.08);
            border-color: rgba(132, 204, 22, 0.3);
        }

        .court-img-wrapper {
            position: relative;
            height: 220px;
            overflow: hidden;
        }

        .court-img-card {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: var(--transition-smooth);
        }

        .court-card:hover .court-img-card {
            transform: scale(1.05);
        }

        .court-price-badge {
            position: absolute;
            bottom: 15px;
            right: 15px;
            background-color: var(--dark-slate);
            color: var(--lime-bright);
            font-family: 'Outfit', sans-serif;
            font-weight: 700;
            font-size: 15px;
            padding: 6px 14px;
            border-radius: 50px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.15);
        }

        .court-details {
            padding: 24px;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
        }

        .court-name {
            font-size: 20px;
            font-weight: 700;
            color: var(--dark-slate);
            margin-bottom: 10px;
            text-decoration: none;
        }

        .court-name:hover {
            color: var(--lime-green);
        }

        .court-meta {
            display: flex;
            gap: 15px;
            font-size: 14px;
            color: #64748b;
            font-weight: 500;
            margin-bottom: 20px;
            border-bottom: 1px solid #f1f5f9;
            padding-bottom: 15px;
        }

        .court-meta-item {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .court-meta-item i {
            color: var(--lime-green);
        }

        .btn-court-order {
            background-color: var(--light-bg);
            color: var(--dark-slate);
            border: 1px solid var(--border-color);
            font-weight: 700;
            padding: 10px 0;
            border-radius: 12px;
            width: 100%;
            display: block;
            text-align: center;
            text-decoration: none;
            transition: var(--transition-smooth);
            margin-top: auto;
        }

        .btn-court-order:hover {
            background-color: var(--lime-green);
            color: #ffffff;
            border-color: var(--lime-green);
            box-shadow: 0 4px 12px rgba(132,204,22,0.2);
        }

        /* Testimonials Section */
        .testimonials-section {
            background-color: var(--dark-slate);
            color: #ffffff;
            position: relative;
            overflow: hidden;
        }

        .testimonial-card {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 20px;
            padding: 30px;
            height: 100%;
            transition: var(--transition-smooth);
        }

        .testimonial-card:hover {
            background: rgba(255, 255, 255, 0.06);
            border-color: rgba(132, 204, 22, 0.25);
            transform: translateY(-5px);
        }

        .rating-stars {
            color: #fbbf24;
            font-size: 15px;
            margin-bottom: 15px;
        }

        .testimonial-text {
            font-size: 15px;
            line-height: 1.6;
            color: #cbd5e1;
            margin-bottom: 25px;
            font-style: italic;
        }

        .testimonial-client {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .client-avatar {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid var(--lime-green);
        }

        .client-info h6 {
            font-size: 15px;
            font-weight: 700;
            color: #ffffff;
            margin-bottom: 2px;
        }

        .client-info span {
            font-size: 12px;
            color: #94a3b8;
            font-weight: 500;
        }

        /* CTA Newsletter Box */
        .cta-box-card {
            background: linear-gradient(135deg, var(--lime-green) 0%, #76b813 100%);
            border-radius: 24px;
            padding: 50px;
            color: #ffffff;
            box-shadow: 0 15px 35px rgba(132,204,22,0.15);
            position: relative;
            overflow: hidden;
        }

        .cta-box-card::before {
            content: '';
            position: absolute;
            top: -20px;
            right: -20px;
            width: 150px;
            height: 150px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.1);
        }

        .cta-title {
            font-size: 32px;
            font-weight: 800;
            margin-bottom: 15px;
        }

        .cta-desc {
            font-size: 16px;
            opacity: 0.9;
            margin-bottom: 0;
            max-width: 600px;
            line-height: 1.6;
        }

        .cta-input-group {
            display: flex;
            gap: 10px;
            max-width: 450px;
            margin-left: auto;
        }

        .cta-input {
            border: none;
            padding: 15px 20px;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 500;
            flex-grow: 1;
        }

        .cta-input:focus {
            outline: none;
        }

        .btn-cta-submit {
            background-color: var(--dark-slate);
            color: #ffffff;
            border: none;
            padding: 15px 25px;
            border-radius: 12px;
            font-weight: 700;
            font-family: 'Outfit', sans-serif;
            transition: var(--transition-smooth);
        }

        .btn-cta-submit:hover {
            background-color: #ffffff;
            color: var(--dark-slate);
        }
    </style>
}

