                            <div class="text-muted small text-uppercase fw-bold mb-1">Mã khách hàng</div>
                            <div class="fw-semibold text-dark fs-5">KH-8842</div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small text-uppercase fw-bold mb-1">Họ và Tên</div>
                            <div class="fw-semibold text-dark fs-5">Nguyễn Văn Minh</div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small text-uppercase fw-bold mb-1">Số điện thoại</div>
                            <div class="fw-semibold text-dark fs-5">0987.654.321</div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small text-uppercase fw-bold mb-1">Địa chỉ email</div>
                            <div class="fw-semibold text-dark fs-5">minh.nguyen@gmail.com</div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small text-uppercase fw-bold mb-1">Địa chỉ thường trú</div>
                            <div class="fw-semibold text-dark fs-5">144 Xuân Thủy, Cầu Giấy, Hà Nội</div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small text-uppercase fw-bold mb-1">Ngày tham gia hệ thống</div>
                            <div class="fw-semibold text-dark fs-5">15/01/2026</div>
                        </div>
                    </div>
                </div>

                <!-- Section 2: Booking History -->
                <div id="booking-history" class="dashboard-content-card">
