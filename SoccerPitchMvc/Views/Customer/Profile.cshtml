                                    <td class="text-success fw-bold">180,000đ</td>
                                    <td><span class="badge-status paid"><i class="fa-solid fa-circle-check"></i> Đã thanh toán</span></td>
                                </tr>
                                <tr>
                                    <td class="fw-bold">#BK-8854</td>
                                    <td>Sân Pickleball A - Elite Center</td>
                                    <td>12/06/2026</td>
