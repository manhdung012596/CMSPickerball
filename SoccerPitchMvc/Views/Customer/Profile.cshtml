                                    <td class="text-success fw-bold">250,000đ</td>
                                    <td><span class="badge-status pending"><i class="fa-solid fa-hourglass-half"></i> Đang chờ duyệt</span></td>
                                </tr>
                                <tr>
                                    <td class="fw-bold">#BK-8712</td>
                                    <td>Sân Pickleball C - Elite Center</td>
                                    <td>05/06/2026</td>
                                    <td>15:00 - 16:30</td>
                                    <td class="text-danger fw-bold">180,000đ</td>
                                    <td><span class="badge-status cancelled"><i class="fa-solid fa-circle-xmark"></i> Đã hủy</span></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Section 3: My Vouchers -->
                <div id="my-vouchers" class="dashboard-content-card">
