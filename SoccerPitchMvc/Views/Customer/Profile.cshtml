@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Trang cá nhân - EliteAcademy</title>
    
    <!-- CDNs -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --dark-blue: #1e293b;
            --dark-slate: #0f172a;
            --lime-green: #84cc16;
            --lime-bright: #9ef01a;
            --light-bg: #f8fafc;
            --border-color: #e2e8f0;
            --card-shadow: 0 10px 30px rgba(15, 23, 42, 0.04);
            --transition-smooth: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--light-bg);
            color: #334155;
            margin: 0;
            padding-top: 90px;
        }

        h1, h2, h3, h4, h5, h6, .brand-logo, .btn-booking, .member-badge {
            font-family: 'Outfit', sans-serif;
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f5f9;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }

        /* Premium Navbar */
        .navbar-custom {
            background-color: var(--dark-slate);
            border-bottom: 2px solid rgba(132, 204, 22, 0.1);
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1030;
            padding: 15px 0;
            transition: var(--transition-smooth);
        }

        .brand-logo {
            font-size: 24px;
            font-weight: 800;
            color: #ffffff;
            text-decoration: none;
            letter-spacing: -0.5px;
        }

        .brand-logo span {
            color: var(--lime-bright);
        }

        .nav-link-custom {
            color: rgba(255, 255, 255, 0.85);
            font-weight: 500;
            font-size: 15px;
            padding: 8px 16px;
            text-decoration: none;
            transition: var(--transition-smooth);
            border-bottom: 2px solid transparent;
        }

        .nav-link-custom:hover, .nav-link-custom.active {
            color: var(--lime-bright);
        }

        .btn-booking {
            background-color: var(--lime-bright);
            color: var(--dark-slate);
            font-weight: 700;
            font-size: 15px;
            padding: 10px 24px;
            border-radius: 50px;
            text-decoration: none;
            border: none;
            box-shadow: 0 4px 12px rgba(132, 204, 22, 0.25);
            transition: var(--transition-smooth);
        }

        .btn-booking:hover {
            background-color: #ffffff;
            color: var(--dark-slate);
            transform: translateY(-2px);
            box-shadow: 0 6px 18px rgba(255, 255, 255, 0.2);
        }

        .user-nav-profile {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 5px 15px;
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 50px;
            color: #ffffff;
            text-decoration: none;
            margin-left: 15px;
            transition: var(--transition-smooth);
        }

        .user-nav-profile:hover {
            background: rgba(132, 204, 22, 0.15);
            border-color: var(--lime-bright);
            color: var(--lime-bright);
        }

        .user-nav-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid var(--lime-green);
        }

        /* Customer Dashboard Content */
        .dashboard-container {
            max-width: 1200px;
            margin: 30px auto 60px;
            padding: 0 20px;
        }

        /* Profile Banner Card */
        .profile-hero-card {
            background-color: var(--dark-slate);
            border-radius: 24px;
            padding: 40px;
            color: #ffffff;
            position: relative;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(15, 23, 42, 0.15);
            margin-bottom: 30px;
        }

        .profile-hero-card::before {
            content: '';
            position: absolute;
            top: -50px;
            right: -50px;
            width: 300px;
            height: 300px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(132, 204, 22, 0.15) 0%, transparent 70%);
            z-index: 0;
            pointer-events: none;
        }

        /* Customer Image Curved Outline */
        .customer-avatar-wrapper {
            position: relative;
            width: 150px;
            height: 150px;
            margin: 0 auto;
        }

        .customer-avatar {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            object-fit: cover;
            position: relative;
            z-index: 2;
            border: 4px solid var(--dark-slate);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.25);
        }

        .customer-avatar-wrapper::before {
            content: '';
            position: absolute;
            top: -6px;
            left: -6px;
            right: -6px;
            bottom: -6px;
            border-radius: 50%;
            border: 2.5px solid var(--lime-bright);
            z-index: 1;
            clip-path: polygon(0 0, 100% 0, 100% 80%, 0 100%);
            transform: rotate(-10deg);
        }

        .customer-avatar-wrapper::after {
            content: '';
            position: absolute;
            top: -10px;
            left: -10px;
            right: -10px;
            bottom: -10px;
            border-radius: 50%;
            border: 1px dashed var(--lime-bright);
            z-index: 0;
            opacity: 0.5;
            transform: rotate(15deg);
        }

        .member-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: linear-gradient(135deg, #fbbf24 0%, #d97706 100%);
            color: var(--dark-slate);
            font-weight: 700;
            font-size: 13px;
            text-transform: uppercase;
            padding: 6px 14px;
            border-radius: 50px;
            box-shadow: 0 4px 10px rgba(217, 119, 6, 0.25);
        }

        .stats-summary-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
            gap: 15px;
            margin-top: 15px;
        }

        .stats-summary-item {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 16px;
            padding: 15px;
            text-align: center;
            transition: var(--transition-smooth);
        }

        .stats-summary-item:hover {
            background: rgba(132, 204, 22, 0.08);
            border-color: rgba(132, 204, 22, 0.3);
            transform: translateY(-2px);
        }

        .stats-summary-val {
            font-size: 24px;
            font-weight: 700;
            color: var(--lime-bright);
            margin-bottom: 2px;
            font-family: 'Outfit', sans-serif;
        }

        .stats-summary-lbl {
            font-size: 12px;
            font-weight: 500;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* Sidebar Navigation Menu */
        .dashboard-nav-card {
            background: #ffffff;
            border-radius: 20px;
            border: 1px solid var(--border-color);
            padding: 15px;
            box-shadow: var(--card-shadow);
            position: sticky;
            top: 110px;
        }

        .dash-nav-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 18px;
            color: #475569;
            font-weight: 600;
            text-decoration: none;
            border-radius: 12px;
            margin-bottom: 5px;
            transition: var(--transition-smooth);
        }

        .dash-nav-link i {
            font-size: 18px;
            color: #64748b;
            transition: var(--transition-smooth);
        }

        .dash-nav-link:hover, .dash-nav-link.active {
            background-color: rgba(132, 204, 22, 0.1);
            color: var(--dark-slate);
        }

        .dash-nav-link.active i {
            color: var(--lime-green);
        }

        /* Section Cards */
        .dashboard-content-card {
            background: #ffffff;
            border-radius: 20px;
            border: 1px solid var(--border-color);
            padding: 30px;
            box-shadow: var(--card-shadow);
            margin-bottom: 30px;
        }

        .card-header-title {
            font-size: 20px;
            font-weight: 700;
            color: var(--dark-slate);
            margin-bottom: 25px;
            position: relative;
            padding-bottom: 10px;
        }

        .card-header-title::after {
            content: '';
            position: absolute;
            left: 0;
            bottom: 0;
            width: 40px;
            height: 3px;
            background-color: var(--lime-green);
            border-radius: 2px;
        }

        /* Booking History Table */
        .table-custom {
            vertical-align: middle;
            margin-bottom: 0;
        }

        .table-custom th {
            background-color: #f8fafc;
            border-bottom: 2px solid var(--border-color);
            color: #64748b;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 12px;
            letter-spacing: 0.5px;
            padding: 15px;
        }

        .table-custom td {
            padding: 15px;
            border-bottom: 1px solid #f1f5f9;
            color: #334155;
            font-weight: 500;
        }

        .badge-status {
            font-weight: 700;
            font-size: 12px;
            padding: 6px 12px;
            border-radius: 50px;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

        .badge-status.paid {
            background-color: rgba(132, 204, 22, 0.12);
            color: #4d7c0f;
        }

        .badge-status.pending {
            background-color: rgba(245, 158, 11, 0.12);
            color: #b45309;
        }

        .badge-status.cancelled {
            background-color: rgba(239, 68, 68, 0.12);
            color: #b91c1c;
        }

        /* Voucher Ticket design */
        .voucher-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
        }

        .voucher-ticket {
            background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
            border: 1.5px dashed var(--lime-green);
            border-radius: 16px;
            padding: 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: relative;
            box-shadow: 0 4px 15px rgba(0,0,0,0.02);
            transition: var(--transition-smooth);
            overflow: hidden;
        }

        .voucher-ticket:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(132,204,22,0.1);
            border-style: solid;
        }

        .voucher-ticket::before, .voucher-ticket::after {
            content: '';
            position: absolute;
            width: 20px;
            height: 20px;
            background-color: var(--light-bg);
            border-radius: 50%;
            left: -10px;
            top: 50%;
            transform: translateY(-50%);
            border-right: 1.5px dashed var(--lime-green);
            z-index: 1;
        }

        .voucher-ticket::after {
            left: auto;
            right: -10px;
            border-right: none;
            border-left: 1.5px dashed var(--lime-green);
        }

        .voucher-info {
            padding-left: 10px;
            flex-grow: 1;
        }

        .voucher-code {
            font-size: 18px;
            font-weight: 800;
            color: var(--dark-slate);
            font-family: 'Outfit', sans-serif;
            letter-spacing: 0.5px;
            margin-bottom: 2px;
        }

        .voucher-desc {
            font-size: 13px;
            color: #64748b;
            font-weight: 500;
            margin-bottom: 8px;
        }

        .voucher-expiry {
            font-size: 11px;
            color: #94a3b8;
            font-weight: 600;
        }

        .btn-copy-voucher {
            background-color: var(--lime-green);
            color: #ffffff;
            border: none;
            font-size: 12px;
            font-weight: 700;
            padding: 8px 12px;
            border-radius: 8px;
            cursor: pointer;
            transition: var(--transition-smooth);
            font-family: 'Outfit', sans-serif;
        }

        .btn-copy-voucher:hover {
            background-color: var(--dark-slate);
        }

        /* Profile Editing Forms */
        .form-label-custom {
            font-size: 13px;
            font-weight: 700;
            color: #475569;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
        }

        .form-control-custom {
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 12px 16px;
            font-size: 15px;
            color: var(--dark-blue);
            font-weight: 500;
            transition: var(--transition-smooth);
        }

        .form-control-custom:focus {
            border-color: var(--lime-green);
            box-shadow: 0 0 0 3px rgba(132, 204, 22, 0.15);
            outline: none;
        }

        .btn-submit-profile {
            background: linear-gradient(135deg, var(--lime-green) 0%, #76b813 100%);
            color: #ffffff;
            font-family: 'Outfit', sans-serif;
            font-weight: 700;
            padding: 12px 30px;
            border-radius: 12px;
            border: none;
            box-shadow: 0 4px 15px rgba(132, 204, 22, 0.2);
            transition: var(--transition-smooth);
        }

        .btn-submit-profile:hover {
            transform: translateY(-1.5px);
            box-shadow: 0 6px 20px rgba(132, 204, 22, 0.3);
            background: var(--dark-slate);
        }
    </style>
</head>
<body>

    <!-- Header Navigation -->
    <nav class="navbar navbar-expand-lg navbar-custom">
        <div class="container">
            <a class="brand-logo" href="/Home">Elite<span>Academy</span></a>
            
            <button class="navbar-toggler border-0 text-white" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
                <i class="fa-solid fa-bars"></i>
            </button>
            
            <div class="collapse navbar-collapse" id="navbarContent">
                <div class="navbar-nav mx-auto">
                    <a class="nav-link-custom" href="/Home">Trang chủ</a>
                    <a class="nav-link-custom" href="#">Giới thiệu</a>
                    <a class="nav-link-custom" href="#">Dịch vụ</a>
                    <a class="nav-link-custom" href="#">Dự án</a>
                    <a class="nav-link-custom" href="#">Chính sách</a>
                    <a class="nav-link-custom" href="#">Tin tức</a>
                </div>
                <div class="d-flex align-items-center">
                    <a href="/admin/dashboard" class="btn-booking">Đặt ngay</a>
                    
                    <!-- Customer Session Active Link -->
                    <a href="/Customer/Profile" class="user-nav-profile">
                        <img src="https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?auto=format&fit=crop&w=80&h=80&q=80" alt="Avatar" class="user-nav-avatar" />
                        <span class="d-none d-sm-inline fw-semibold" style="font-size: 14px;">Nguyễn Văn Minh</span>
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Dashboard Container -->
    <div class="dashboard-container">
        
        <!-- Hero Header -->
        <div class="profile-hero-card">
            <div class="row align-items-center g-4">
                <div class="col-md-3 text-center text-md-start">
                    <div class="customer-avatar-wrapper">
                        <img src="https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?auto=format&fit=crop&w=300&h=300&q=80" alt="Nguyễn Văn Minh" class="customer-avatar" />
                    </div>
                </div>
                <div class="col-md-5 text-center text-md-start">
                    <div class="mb-2">
                        <span class="member-badge">
                            <i class="fa-solid fa-crown"></i> Hạng Vàng (Gold Member)
                        </span>
                    </div>
                    <h2 class="fw-bold mb-1" style="font-size: 32px; font-family: 'Outfit';">Nguyễn Văn Minh</h2>
                    <p class="text-white-50 mb-0"><i class="fa-regular fa-envelope me-2"></i>minh.nguyen@gmail.com</p>
                    <p class="text-white-50 mb-0"><i class="fa-solid fa-phone me-2"></i>0987.654.321</p>
                </div>
                <div class="col-md-4">
                    <div class="stats-summary-grid">
                        <div class="stats-summary-item">
                            <div class="stats-summary-val">24</div>
                            <div class="stats-summary-lbl">Đã đặt</div>
                        </div>
                        <div class="stats-summary-item">
                            <div class="stats-summary-val">36h</div>
                            <div class="stats-summary-lbl">Giờ chơi</div>
                        </div>
                        <div class="stats-summary-item">
                            <div class="stats-summary-val">2,450</div>
                            <div class="stats-summary-lbl">Điểm tích</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <!-- Left Sidebar Navigation -->
            <div class="col-lg-3">
                <div class="dashboard-nav-card">
                    <a href="#personal-info" class="dash-nav-link active">
                        <i class="fa-regular fa-user"></i> Thông tin tài khoản
                    </a>
                    <a href="#booking-history" class="dash-nav-link">
