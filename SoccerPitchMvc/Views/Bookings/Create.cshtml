@model SoccerPitchMvc.Models.Booking

@{
    ViewData["Title"] = "Đặt Sân mới";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0 rounded-3">
                <div class="card-header bg-success text-white py-3">
                    <h4 class="card-title fw-bold mb-0"><i class="bi bi-calendar-plus-fill"></i> Đặt Sân Pickleball</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post" id="bookingForm">
                        @Html.AntiForgeryToken()
                        
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="CustomerId" class="form-label fw-semibold">Khách Hàng <span class="text-danger">*</span></label>
                            <select asp-for="CustomerId" class="form-select" asp-items="ViewBag.CustomerId" required>
                                <option value="">-- Chọn khách hàng --</option>
                            </select>
                            <span asp-validation-for="CustomerId" class="text-danger small"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="PitchId" class="form-label fw-semibold">Sân Pickleball <span class="text-danger">*</span></label>
                                <select asp-for="PitchId" class="form-select" id="pitchSelect" asp-items="ViewBag.PitchId" required>
                                    <option value="">-- Chọn sân Pickleball --</option>
                                </select>
                                <span asp-validation-for="PitchId" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="BookingDate" class="form-label fw-semibold">Ngày Đặt Sân <span class="text-danger">*</span></label>
                                <input asp-for="BookingDate" type="date" class="form-control" id="bookingDate" value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                                <span asp-validation-for="BookingDate" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="TimeSlotId" class="form-label fw-semibold">Khung Giờ Đặt <span class="text-danger">*</span></label>
                            <select asp-for="TimeSlotId" class="form-select" id="timeSlotSelect" required disabled>
                                <option value="">-- Vui lòng chọn Sân trước --</option>
                            </select>
                            <span asp-validation-for="TimeSlotId" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Note" class="form-label fw-semibold">Ghi Chú</label>
                            <textarea asp-for="Note" class="form-control" rows="3" placeholder="Nhập ghi chú yêu cầu đặt sân (ví dụ: cần thêm nước uống, trọng tài...)"></textarea>
                            <span asp-validation-for="Note" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center pt-2 border-top">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Quay Lại
                            </a>
                            <button type="submit" class="btn btn-success px-4" id="submitBtn">
                                <i class="bi bi-check-circle"></i> Đặt Sân Ngay
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        $(document).ready(function () {
            // Sự kiện khi chọn Sân Pickleball
            $("#pitchSelect").change(function () {
                var pitchId = $(this).val();
                var timeSlotSelect = $("#timeSlotSelect");
                
                if (pitchId) {
                    // Gọi Ajax lấy danh sách khung giờ của sân được chọn
                    $.getJSON("/Bookings/GetTimeSlotsByPitch", { pitchId: pitchId }, function (data) {
                        timeSlotSelect.empty();
                        timeSlotSelect.append('<option value="">-- Chọn khung giờ --</option>');
                        
                        if (data && data.length > 0) {
                            $.each(data, function (index, item) {
                                timeSlotSelect.append('<option value="' + item.id + '">' + item.display + '</option>');
                            });
                            timeSlotSelect.removeAttr("disabled");
                        } else {
                            timeSlotSelect.append('<option value="">Không có khung giờ nào được cấu hình</option>');
                            timeSlotSelect.attr("disabled", "disabled");
                        }
                    });
                } else {
                    timeSlotSelect.empty();
                    timeSlotSelect.append('<option value="">-- Vui lòng chọn Sân trước --</option>');
                    timeSlotSelect.attr("disabled", "disabled");
                }
            });

            // Tự động kích hoạt thay đổi nếu sân đã được chọn trước (khi quay lại do lỗi ModelState)
            if ($("#pitchSelect").val()) {
                $("#pitchSelect").trigger("change");
            }
        });
    </script>
}
