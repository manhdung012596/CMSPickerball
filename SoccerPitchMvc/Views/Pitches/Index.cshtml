@model IEnumerable<SoccerPitchMvc.Models.Pitch>

@{
    ViewData["Title"] = "Danh sách Sân Pickleball";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div>
            <h2 class="fw-bold text-dark mb-1"><i class="bi bi-dribbble text-success"></i> Quản lý Sân Pickleball</h2>
            <p class="text-muted">Danh sách các sân Pickleball của trung tâm</p>
        </div>
        <a asp-action="Create" class="btn btn-success btn-lg shadow-sm">
            <i class="bi bi-plus-lg"></i> Thêm Sân Mới
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="py-3 px-4">Tên Sân</th>
                            <th class="py-3">Giá Thuê / Giờ</th>
                            <th class="py-3">Trạng Thái</th>
                            <th class="py-3">Ngày Tạo</th>
                            <th class="py-3 text-end px-4">Hành Động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox-fill display-4 d-block mb-3 text-secondary"></i>
                                    Chưa có sân Pickleball nào được tạo.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-bold text-dark py-3 px-4">@item.Name</td>
                                    <td class="fw-semibold text-success">130,000 VNĐ</td>
                                    <td>
                                        @if (item.Status == 0)
                                        {
                                            <span class="badge bg-success"><i class="bi bi-check-circle-fill"></i> Đang Hoạt Động</span>
                                        }
                                        else if (item.Status == 1)
                                        {
                                            <span class="badge bg-warning text-dark"><i class="bi bi-cone-striped"></i> Bảo Trì</span>
                                        }
                                    </td>
                                    <td class="text-muted">@item.CreatedDate.ToString("dd/MM/yyyy")</td>
                                    <td class="text-end px-4">
                                        <div class="btn-group shadow-sm">
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">
                                                <i class="bi bi-pencil-square"></i> Sửa
                                            </a>
                                            <button type="button" class="btn btn-outline-danger btn-sm" data-bs-toggle="modal" data-bs-target="#deleteModal-@item.Id">
                                                <i class="bi bi-trash-fill"></i> Xóa
                                            </button>
                                        </div>

                                        <!-- Delete Confirmation Modal -->
                                        <div class="modal fade" id="deleteModal-@item.Id" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
                                            <div class="modal-dialog modal-dialog-centered">
                                                <div class="modal-content border-0 shadow-lg">
                                                    <div class="modal-header bg-danger text-white">
                                                        <h5 class="modal-title fw-bold" id="deleteModalLabel"><i class="bi bi-exclamation-triangle-fill"></i> Xác nhận xóa</h5>
                                                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                                                    </div>
                                                    <div class="modal-body text-start py-4">
                                                        Bạn có chắc chắn muốn xóa sân Pickleball <strong class="text-danger">@item.Name</strong> không? Hành động này sẽ thực hiện xóa mềm (ẩn khỏi danh sách).
                                                    </div>
                                                    <div class="modal-footer bg-light border-0">
                                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                                            <button type="submit" class="btn btn-danger px-4">Đồng Ý Xóa</button>
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
