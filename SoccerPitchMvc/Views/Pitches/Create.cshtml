@model SoccerPitchMvc.Models.Pitch

@{
    ViewData["Title"] = "Thêm Sân mới";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0 rounded-3">
                <div class="card-header bg-success text-white py-3">
                    <h4 class="card-title fw-bold mb-0"><i class="bi bi-plus-circle-fill"></i> Thêm Sân Pickleball Mới</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post" class="needs-validation" novalidate>
                        @Html.AntiForgeryToken()
                        
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-semibold">Tên Sân Pickleball <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" placeholder="Nhập tên sân (Ví dụ: Sân 5A, Sân 7B)" required />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Type" class="form-label fw-semibold">Loại Sân <span class="text-danger">*</span></label>
                                <select asp-for="Type" class="form-select" required>
                                    <option value="">Chọn loại sân...</option>
                                    <option value="5">Sân 5 người</option>
                                    <option value="7">Sân 7 người</option>
                                    <option value="11">Sân 11 người</option>
                                </select>
                                <span asp-validation-for="Type" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Status" class="form-label fw-semibold">Trạng Thái <span class="text-danger">*</span></label>
                                <select asp-for="Status" class="form-select" required>
                                    <option value="0">Đang Hoạt Động</option>
                                    <option value="1">Bảo Trì</option>
                                </select>
                                <span asp-validation-for="Status" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="PricePerHour" class="form-label fw-semibold">Giá Thuê / Giờ (VNĐ) <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">đ</span>
                                <input asp-for="PricePerHour" type="number" step="1000" class="form-control" placeholder="Nhập giá thuê (Ví dụ: 200000)" required />
                            </div>
                            <span asp-validation-for="PricePerHour" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center pt-2 border-top">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Quay Lại
                            </a>
                            <button type="submit" class="btn btn-success px-4">
                                <i class="bi bi-save"></i> Lưu Sân Pickleball
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
