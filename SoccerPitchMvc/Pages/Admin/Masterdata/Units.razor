@page "/admin/masterdata/units"
@layout AdminLayout
@using SoccerPitchMvc.Models
@using SoccerPitchMvc.Services
@inject IMasterdataService MasterdataService
@inject ToastService Toast

<PageTitle>Đơn vị tính - Quản trị</PageTitle>

<div class="page-header d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="page-title"><i class="fas fa-weight-scale me-2 text-primary"></i>Đơn vị tính</h1>
        <p class="text-muted mb-0">Quản lý các đơn vị đo lường dùng cho sản phẩm và dịch vụ</p>
    </div>
    <button class="btn btn-primary" @onclick="ShowCreateModal">
        <i class="fas fa-plus me-1"></i> Thêm đơn vị
    </button>
</div>

<div class="row g-4">
    <!-- Units Table -->
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body p-0">
                @if (IsLoading)
                {
                    <div class="text-center py-5">
                        <div class="spinner-border text-primary"></div>
                    </div>
                }
                else if (!UnitList.Any())
                {
                    <div class="text-center py-5">
                        <i class="fas fa-weight-scale fa-3x text-muted mb-3"></i>
                        <p class="text-muted">Chưa có đơn vị tính nào.</p>
                        <button class="btn btn-primary" @onclick="ShowCreateModal"><i class="fas fa-plus me-1"></i>Thêm đơn vị</button>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th width="40">#</th>
                                    <th>Tên đơn vị</th>
                                    <th class="text-center">Ký hiệu</th>
                                    <th>Mô tả</th>
                                    <th class="text-center">Thứ tự</th>
                                    <th class="text-center">Trạng thái</th>
                                    <th width="120" class="text-center">Hành động</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var (unit, index) in UnitList.Select((u, i) => (u, i + 1)))
                                {
                                    <tr>
                                        <td class="text-muted fw-semibold">@index</td>
                                        <td>
                                            <div class="fw-semibold">@unit.Name</div>
                                        </td>
                                        <td class="text-center">
                                            @if (!string.IsNullOrEmpty(unit.Symbol))
                                            {
                                                <code class="badge bg-primary px-2 py-1 fs-6">@unit.Symbol</code>
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                        <td>
                                            <span class="text-muted small">@(unit.Description ?? "—")</span>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge bg-light text-dark border">@unit.SortOrder</span>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge bg-@unit.StatusBadge">@unit.StatusText</span>
                                        </td>
                                        <td class="text-center">
                                            <div class="btn-group btn-group-sm">
                                                <button class="btn btn-outline-primary" @onclick="() => ShowEditModal(unit)"><i class="fas fa-edit"></i></button>
                                                <button class="btn btn-outline-danger" @onclick="() => ConfirmDelete(unit)"><i class="fas fa-trash"></i></button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="card-footer bg-light">
                        <span class="text-muted small">Tổng: <strong>@UnitList.Count</strong> đơn vị tính</span>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Quick Add / Suggestions -->
    <div class="col-lg-4">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-light">
                <h6 class="mb-0"><i class="fas fa-lightbulb text-warning me-2"></i>Thêm nhanh đơn vị phổ biến</h6>
            </div>
            <div class="card-body">
                <p class="text-muted small mb-3">Click để thêm nhanh các đơn vị thường dùng:</p>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var suggestion in CommonUnits)
                    {
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => QuickAdd(suggestion.Name, suggestion.Symbol)">
                            <i class="fas fa-plus me-1"></i>@suggestion.Name @(!string.IsNullOrEmpty(suggestion.Symbol) ? $"({suggestion.Symbol})" : "")
                        </button>
                    }
                </div>
            </div>
        </div>

        <!-- Unit Preview -->
        <div class="card shadow-sm border-0 mt-3">
            <div class="card-header bg-light">
                <h6 class="mb-0"><i class="fas fa-eye text-info me-2"></i>Tổng quan</h6>
            </div>
            <div class="card-body">
                <div class="row text-center g-3">
                    <div class="col-6">
                        <div class="bg-success bg-opacity-10 rounded p-3">
                            <div class="fs-3 fw-bold text-success">@UnitList.Count(u => u.Status == 1)</div>
                            <div class="small text-muted">Hoạt động</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="bg-secondary bg-opacity-10 rounded p-3">
                            <div class="fs-3 fw-bold text-secondary">@UnitList.Count(u => u.Status == 0)</div>
                            <div class="small text-muted">Ẩn</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Create/Edit Modal -->
@if (ShowModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="fas fa-@(IsEditing ? "edit" : "plus") me-2"></i>@(IsEditing ? "Sửa đơn vị tính" : "Thêm đơn vị tính")</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Tên đơn vị <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" @bind="ModalName" placeholder="VD: Cái, Hộp, Bộ, Giờ..." />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Ký hiệu</label>
                        <input type="text" class="form-control" @bind="ModalSymbol" placeholder="VD: pcs, hrs, kg..." />
                        <div class="form-text">Ký hiệu viết tắt (tùy chọn)</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Mô tả</label>
                        <input type="text" class="form-control" @bind="ModalDescription" placeholder="Mô tả ngắn..." />
                    </div>
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="form-label fw-semibold">Thứ tự</label>
                            <input type="number" class="form-control" @bind="ModalSortOrder" min="0" />
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-semibold">Trạng thái</label>
                            <select class="form-select" @bind="ModalStatus">
                                <option value="1">Hoạt động</option>
                                <option value="0">Ẩn</option>
                            </select>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(ModalError))
                    {
                        <div class="alert alert-danger mt-3 py-2 small"><i class="fas fa-exclamation-circle me-1"></i>@ModalError</div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" @onclick="CloseModal">Hủy</button>
                    <button class="btn btn-primary" @onclick="SaveUnit" disabled="@IsSaving">
                        @if (IsSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        @(IsEditing ? "Lưu thay đổi" : "Thêm đơn vị")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Delete Modal -->
@if (ShowDeleteModal && UnitToDelete != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title"><i class="fas fa-exclamation-triangle me-2"></i>Xác nhận xóa</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => ShowDeleteModal = false"></button>
                </div>
                <div class="modal-body py-3">
                    <p>Xóa đơn vị tính: <strong class="text-danger">@UnitToDelete.DisplayName</strong>?</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" @onclick="() => ShowDeleteModal = false">Hủy</button>
                    <button class="btn btn-danger" @onclick="ExecuteDelete" disabled="@IsDeleting">
                        @if (IsDeleting) { <span class="spinner-border spinner-border-sm me-1"></span> } Xóa
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<UnitListDto> UnitList = new();
    private bool IsLoading = true;
    private bool ShowModal = false;
    private bool ShowDeleteModal = false;
    private bool IsEditing = false;
    private bool IsSaving = false;
    private bool IsDeleting = false;
    private UnitListDto? UnitToDelete;

    private int ModalId = 0;
    private string ModalName = string.Empty;
    private string ModalSymbol = string.Empty;
    private string ModalDescription = string.Empty;
    private int ModalSortOrder = 0;
    private int ModalStatus = 1;
    private string ModalError = string.Empty;

    private record UnitSuggestion(string Name, string Symbol);
    private List<UnitSuggestion> CommonUnits = new()
    {
        new("Cái", "pcs"), new("Hộp", "box"), new("Bộ", "set"),
        new("Giờ", "hr"), new("Buổi", ""), new("Ngày", "day"),
        new("Tháng", "mo"), new("Kilogram", "kg"), new("Gram", "g"),
        new("Đôi", "pr"),
    };

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        IsLoading = true;
        UnitList = await MasterdataService.GetAllUnitsAsync();
        IsLoading = false;
    }

    private void ShowCreateModal()
    {
        IsEditing = false; ModalId = 0; ModalName = string.Empty; ModalSymbol = string.Empty;
        ModalDescription = string.Empty; ModalSortOrder = 0; ModalStatus = 1; ModalError = string.Empty;
        ShowModal = true;
    }

    private void ShowEditModal(UnitListDto unit)
    {
        IsEditing = true; ModalId = unit.Id; ModalName = unit.Name; ModalSymbol = unit.Symbol ?? string.Empty;
        ModalDescription = unit.Description ?? string.Empty; ModalSortOrder = unit.SortOrder;
        ModalStatus = unit.Status; ModalError = string.Empty; ShowModal = true;
    }

    private async Task QuickAdd(string name, string symbol)
    {
        var result = await MasterdataService.CreateUnitAsync(new CreateUnitDto { Name = name, Symbol = symbol, Status = 1 });
        if (result.Success) { Toast.ShowSuccess(result.Message); await LoadData(); }
        else Toast.ShowError(result.Message);
    }

    private void CloseModal() { ShowModal = false; ModalError = string.Empty; }

    private async Task SaveUnit()
    {
        if (string.IsNullOrWhiteSpace(ModalName)) { ModalError = "Tên đơn vị không được để trống!"; return; }
        IsSaving = true; ModalError = string.Empty;

        (bool Success, string Message) result;
        if (IsEditing)
            result = await MasterdataService.UpdateUnitAsync(new UpdateUnitDto
            {
                Id = ModalId, Name = ModalName, Symbol = ModalSymbol,
                Description = ModalDescription, SortOrder = ModalSortOrder, Status = ModalStatus
            });
        else
            result = await MasterdataService.CreateUnitAsync(new CreateUnitDto
            {
                Name = ModalName, Symbol = ModalSymbol,
                Description = ModalDescription, SortOrder = ModalSortOrder, Status = ModalStatus
            });

        IsSaving = false;
        if (result.Success) { Toast.ShowSuccess(result.Message); CloseModal(); await LoadData(); }
        else ModalError = result.Message;
    }

    private void ConfirmDelete(UnitListDto unit) { UnitToDelete = unit; ShowDeleteModal = true; }

    private async Task ExecuteDelete()
    {
        if (UnitToDelete == null) return;
        IsDeleting = true;
        var result = await MasterdataService.DeleteUnitAsync(UnitToDelete.Id);
        IsDeleting = false; ShowDeleteModal = false;
        if (result.Success) { Toast.ShowSuccess(result.Message); await LoadData(); }
        else Toast.ShowError(result.Message);
        UnitToDelete = null;
    }
}