@page "/admin/masterdata/default-slots"
@layout AdminLayout
@using SoccerPitchMvc.Models
@using SoccerPitchMvc.Services
@inject IMasterdataService MasterdataService
@inject ToastService Toast

<PageTitle>Khung giờ mặc định - Quản trị</PageTitle>

<div class="page-header d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="page-title"><i class="fas fa-clock me-2 text-primary"></i>Khung giờ mặc định</h1>
        <p class="text-muted mb-0">Cấu hình các khung giờ áp dụng cho tất cả sân Pickleball</p>
    </div>
    <button class="btn btn-primary" @onclick="ShowCreateModal">
        <i class="fas fa-plus me-1"></i> Thêm khung giờ
    </button>
</div>

<!-- Info Banner -->
<div class="alert alert-info alert-dismissible border-0 shadow-sm mb-4">
    <i class="fas fa-info-circle me-2"></i>
    <strong>Lưu ý:</strong> Các khung giờ mặc định này sẽ được áp dụng tự động khi tạo sân mới. Bạn có thể ghi đè giá cho từng khung giờ cụ thể.
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>

<!-- Time Slots Grid -->
<div class="card shadow-sm">
    <div class="card-body p-0">
        @if (IsLoading)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-primary"></div>
                <p class="mt-2 text-muted">Đang tải...</p>
            </div>
        }
        else if (!TimeSlots.Any())
        {
            <div class="text-center py-5">
                <i class="fas fa-clock fa-3x text-muted mb-3"></i>
                <p class="text-muted">Chưa có khung giờ nào.</p>
                <button class="btn btn-primary" @onclick="ShowCreateModal">
                    <i class="fas fa-plus me-1"></i>Thêm khung giờ đầu tiên
                </button>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th width="40">#</th>
                            <th>Tên khung giờ</th>
                            <th class="text-center">Thời gian</th>
                            <th class="text-center">Loại ngày</th>
                            <th class="text-center">Giá override</th>
                            <th class="text-center">Thứ tự</th>
                            <th class="text-center">Trạng thái</th>
                            <th width="120" class="text-center">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var (slot, index) in TimeSlots.Select((s, i) => (s, i + 1)))
                        {
                            <tr>
                                <td class="text-muted fw-semibold">@index</td>
                                <td>
                                    <div class="fw-semibold">@slot.Name</div>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-primary fs-6 px-3 py-2 font-monospace">
                                        <i class="fas fa-clock me-1"></i>@slot.TimeDisplay
                                    </span>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-@slot.DayTypeBadge">@slot.DayTypeText</span>
                                </td>
                                <td class="text-center">
                                    @if (slot.PriceOverride.HasValue)
                                    {
                                        <span class="text-success fw-semibold">@slot.PriceDisplay</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">@slot.PriceDisplay</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-light text-dark border">@slot.SortOrder</span>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-@slot.StatusBadge">@slot.StatusText</span>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm">
                                        <button class="btn btn-outline-primary" title="Sửa" @onclick="() => ShowEditModal(slot)">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <button class="btn btn-outline-danger" title="Xóa" @onclick="() => ConfirmDelete(slot)">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="card-footer bg-light">
                <span class="text-muted small">Tổng: <strong>@TimeSlots.Count</strong> khung giờ</span>
            </div>
        }
    </div>
</div>

<!-- Create/Edit Modal -->
@if (ShowModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        <i class="fas fa-@(IsEditing ? "edit" : "plus-circle") me-2"></i>
                        @(IsEditing ? "Sửa khung giờ" : "Thêm khung giờ mới")
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label fw-semibold">Tên khung giờ <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" @bind="ModalName" placeholder="VD: Buổi sáng sớm, Giờ cao điểm..." />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Loại ngày</label>
                            <select class="form-select" @bind="ModalDayType">
                                <option value="0">Tất cả ngày</option>
                                <option value="1">Ngày thường (T2-T6)</option>
                                <option value="2">Cuối tuần (T7-CN)</option>
                                <option value="3">Ngày lễ</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Giờ bắt đầu</label>
                            <select class="form-select" @bind="ModalStartHour">
                                @for (int h = 5; h <= 23; h++)
                                {
                                    <option value="@h">@h.ToString("D2"):00</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Phút bắt đầu</label>
                            <select class="form-select" @bind="ModalStartMinute">
                                <option value="0">:00</option>
                                <option value="30">:30</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Giờ kết thúc</label>
                            <select class="form-select" @bind="ModalEndHour">
                                @for (int h = 5; h <= 24; h++)
                                {
                                    <option value="@h">@h.ToString("D2"):00</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Phút kết thúc</label>
                            <select class="form-select" @bind="ModalEndMinute">
                                <option value="0">:00</option>
                                <option value="30">:30</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Giá override (VNĐ/giờ)</label>
                            <input type="number" class="form-control" @bind="ModalPriceOverride" placeholder="Để trống = giá mặc định" min="0" />
                            <div class="form-text">Để trống nếu dùng giá sân mặc định</div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Thứ tự sắp xếp</label>
                            <input type="number" class="form-control" @bind="ModalSortOrder" min="0" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Trạng thái</label>
                            <select class="form-select" @bind="ModalStatus">
                                <option value="1">Hoạt động</option>
                                <option value="0">Ẩn</option>
                            </select>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(ModalError))
                    {
                        <div class="alert alert-danger mt-3 py-2"><i class="fas fa-exclamation-circle me-1"></i>@ModalError</div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" @onclick="CloseModal"><i class="fas fa-times me-1"></i>Hủy</button>
                    <button class="btn btn-primary" @onclick="SaveSlot" disabled="@IsSaving">
                        @if (IsSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        else { <i class="fas fa-save me-1"></i> }
                        @(IsEditing ? "Lưu thay đổi" : "Thêm khung giờ")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Delete Modal -->
@if (ShowDeleteModal && SlotToDelete != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title"><i class="fas fa-exclamation-triangle me-2"></i>Xác nhận xóa</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => ShowDeleteModal = false"></button>
                </div>
                <div class="modal-body py-4">
                    <p>Xóa khung giờ: <strong class="text-danger">@SlotToDelete.Name</strong>?</p>
                    <p class="text-muted small">(@SlotToDelete.TimeDisplay)</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" @onclick="() => ShowDeleteModal = false">Hủy</button>
                    <button class="btn btn-danger" @onclick="ExecuteDelete" disabled="@IsDeleting">
                        @if (IsDeleting) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Xóa
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<DefaultTimeSlotListDto> TimeSlots = new();
    private bool IsLoading = true;
    private bool ShowModal = false;
    private bool ShowDeleteModal = false;
    private bool IsEditing = false;
    private bool IsSaving = false;
    private bool IsDeleting = false;
    private DefaultTimeSlotListDto? SlotToDelete;

    // Modal fields
    private int ModalId = 0;
    private string ModalName = string.Empty;
    private int ModalStartHour = 6;
    private int ModalStartMinute = 0;
    private int ModalEndHour = 7;
    private int ModalEndMinute = 0;
    private int ModalDayType = 0;
    private decimal? ModalPriceOverride = null;
    private int ModalSortOrder = 0;
    private int ModalStatus = 1;
    private string ModalError = string.Empty;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        IsLoading = true;
        TimeSlots = await MasterdataService.GetAllTimeSlotsAsync();
        IsLoading = false;
    }

    private void ShowCreateModal()
    {
        IsEditing = false; ModalId = 0;
        ModalName = string.Empty; ModalStartHour = 6; ModalStartMinute = 0;
        ModalEndHour = 7; ModalEndMinute = 0; ModalDayType = 0;
        ModalPriceOverride = null; ModalSortOrder = 0; ModalStatus = 1;
        ModalError = string.Empty; ShowModal = true;
    }

    private void ShowEditModal(DefaultTimeSlotListDto slot)
    {
        IsEditing = true; ModalId = slot.Id;
        ModalName = slot.Name; ModalStartHour = slot.StartHour; ModalStartMinute = slot.StartMinute;
        ModalEndHour = slot.EndHour; ModalEndMinute = slot.EndMinute; ModalDayType = slot.DayType;
        ModalPriceOverride = slot.PriceOverride; ModalSortOrder = slot.SortOrder; ModalStatus = slot.Status;
        ModalError = string.Empty; ShowModal = true;
    }

    private void CloseModal() { ShowModal = false; ModalError = string.Empty; }

    private async Task SaveSlot()
    {
        if (string.IsNullOrWhiteSpace(ModalName)) { ModalError = "Tên khung giờ không được để trống!"; return; }
        IsSaving = true; ModalError = string.Empty;

        (bool Success, string Message) result;
        if (IsEditing)
            result = await MasterdataService.UpdateTimeSlotAsync(new UpdateDefaultTimeSlotDto
            {
                Id = ModalId, Name = ModalName, StartHour = ModalStartHour, StartMinute = ModalStartMinute,
                EndHour = ModalEndHour, EndMinute = ModalEndMinute, DayType = ModalDayType,
                PriceOverride = ModalPriceOverride, SortOrder = ModalSortOrder, Status = ModalStatus
            });
        else
            result = await MasterdataService.CreateTimeSlotAsync(new CreateDefaultTimeSlotDto
            {
                Name = ModalName, StartHour = ModalStartHour, StartMinute = ModalStartMinute,
                EndHour = ModalEndHour, EndMinute = ModalEndMinute, DayType = ModalDayType,
                PriceOverride = ModalPriceOverride, SortOrder = ModalSortOrder, Status = ModalStatus
            });

        IsSaving = false;
        if (result.Success) { Toast.ShowSuccess(result.Message); CloseModal(); await LoadData(); }
        else ModalError = result.Message;
    }

    private void ConfirmDelete(DefaultTimeSlotListDto slot) { SlotToDelete = slot; ShowDeleteModal = true; }

    private async Task ExecuteDelete()
    {
        if (SlotToDelete == null) return;
        IsDeleting = true;
        var result = await MasterdataService.DeleteTimeSlotAsync(SlotToDelete.Id);
        IsDeleting = false; ShowDeleteModal = false;
        if (result.Success) { Toast.ShowSuccess(result.Message); await LoadData(); }
        else Toast.ShowError(result.Message);
        SlotToDelete = null;
    }
}