@page "/admin/finance/reconciliation"
@layout AdminLayout
@using SoccerPitchMvc.Models
@using SoccerPitchMvc.Services
@inject IFinanceService FinanceService
@inject ToastService Toast

<PageTitle>Đối soát dòng tiền - Sổ quỹ</PageTitle>

<div class="page-header d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="page-title"><i class="fa-solid fa-scale-balanced me-2 text-primary"></i>Đối soát quỹ</h1>
        <p class="text-muted mb-0">Cân đối và xác thực lượng tiền mặt thực tế trong két sắt so với sổ sách trước khi chốt ca trực</p>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Reconciliation Form Workspace -->
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-calculator me-2 text-primary"></i>Phòng đối soát quỹ</h5>
            </div>
            <div class="card-body py-4">
                <div class="mb-4">
                    <label class="form-label text-muted small fw-semibold text-uppercase">Số dư tiền mặt trên sổ sách</label>
                    <div class="d-flex align-items-baseline text-primary">
                        <span class="fs-1 fw-bold">@ExpectedCash.ToString("N0")</span>
                        <span class="fs-5 ms-1">đ</span>
                    </div>
                    <div class="form-text small text-muted"><i class="fa-solid fa-circle-info"></i> Đây là tổng thu tiền mặt trừ đi tổng chi tiền mặt ghi nhận trên hệ thống.</div>
                </div>

                <div class="mb-4">
                    <label class="form-label text-muted small fw-semibold text-uppercase">Số tiền mặt kiểm đếm thực tế <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <input type="number" class="form-control form-control-lg text-end text-success fw-bold" 
                               @bind="ActualCash" @bind:event="oninput" placeholder="Nhập số tiền mặt thực tế..." />
                        <span class="input-group-text">đ</span>
                    </div>
                </div>

                <!-- Difference display -->
                <div class="mb-4">
                    <label class="form-label text-muted small fw-semibold text-uppercase">Chênh lệch thừa / thiếu</label>
                    @{
                        decimal diff = ActualCash - ExpectedCash;
                        string textClass = diff == 0 ? "text-success" : (diff > 0 ? "text-warning" : "text-danger");
                        string prefix = diff > 0 ? "+" : "";
                    }
                    <div class="d-flex align-items-baseline @textClass">
                        <span class="fs-2 fw-bold">@prefix@diff.ToString("N0")</span>
                        <span class="fs-5 ms-1">đ</span>
                    </div>
                    
                    @if (diff == 0)
                    {
                        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 mt-1">
                            <i class="fa-solid fa-circle-check me-1"></i>Số liệu khớp tuyệt đối
                        </span>
                    }
                    else if (diff > 0)
                    {
                        <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 mt-1 text-dark">
                            <i class="fa-solid fa-circle-exclamation me-1"></i>Thừa quỹ (Tiền thực tế nhiều hơn sổ sách)
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 mt-1">
                            <i class="fa-solid fa-circle-exclamation me-1"></i>Thiếu quỹ (Tiền thực tế ít hơn sổ sách)
                        </span>
                    }
                </div>

                <div class="mb-3">
                    <label class="form-label small fw-semibold">Người thực hiện đối soát</label>
                    <input type="text" class="form-control form-control-sm" @bind="AuditorName" placeholder="Tên nhân viên đối soát..." />
                </div>

                <button class="btn btn-primary w-100 py-2 fs-5 mt-2" @onclick="SubmitReconciliation" disabled="@IsSubmitting">
                    @if (IsSubmitting)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    }
                    <i class="fa-solid fa-lock me-2"></i>Xác nhận & Chốt quỹ
                </button>
            </div>
        </div>
    </div>

    <!-- Reconciliation Log History -->
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white py-3">
                <h5 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-history me-2 text-secondary"></i>Nhật ký đối soát ca</h5>
            </div>
            <div class="card-body p-0">
                @if (ReconHistory == null || !ReconHistory.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <i class="fa-solid fa-scale-balanced fa-3x text-light mb-3"></i>
                        <p class="mb-0">Chưa có nhật ký đối soát quỹ nào.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Thời điểm</th>
                                    <th class="text-end">Sổ sách</th>
                                    <th class="text-end">Kiểm thực tế</th>
                                    <th class="text-end">Chênh lệch</th>
                                    <th>Đối soát viên</th>
                                    <th class="text-center">Kết quả</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in ReconHistory)
                                {
                                    <tr>
                                        <td class="small">@item.ReconciledAt.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td class="text-end text-muted">@item.ExpectedCash.ToString("N0")đ</td>
                                        <td class="text-end fw-semibold">@item.ActualCash.ToString("N0")đ</td>
                                        <td class="text-end fw-bold @(item.Difference == 0 ? "text-success" : (item.Difference > 0 ? "text-warning" : "text-danger"))">
                                            @(item.Difference > 0 ? "+" : "")@item.Difference.ToString("N0")đ
                                        </td>
                                        <td>@item.Auditor</td>
                                        <td class="text-center">
                                            <span class="badge @item.StatusBadge">@item.Status</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private decimal ExpectedCash = 0;
    private decimal ActualCash = 0;
    private string AuditorName = "Kế toán Admin";
    private List<ReconciliationItemDto> ReconHistory = new();

    private bool IsSubmitting = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        var summary = await FinanceService.GetCashFlowSummaryAsync();
        ExpectedCash = summary.CashBalance;
        ActualCash = ExpectedCash; // default helper input to match expected
        ReconHistory = await FinanceService.GetReconciliationHistoryAsync();
    }

    private async Task SubmitReconciliation()
    {
        if (ActualCash < 0)
        {
            Toast.ShowError("Số tiền mặt thực tế kiểm đếm không thể nhỏ hơn 0.");
            return;
        }
        if (string.IsNullOrWhiteSpace(AuditorName))
        {
            Toast.ShowError("Vui lòng nhập tên người đối soát quỹ.");
            return;
        }

        IsSubmitting = true;
        try
        {
            bool ok = await FinanceService.ReconcileCashAsync(ActualCash);
            if (ok)
            {
                Toast.ShowSuccess("Đã lưu chốt đối soát quỹ ca trực thành công!");
                await LoadData();
            }
            else
            {
                Toast.ShowError("Không thể chốt quỹ.");
            }
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Lỗi chốt quỹ: {ex.Message}");
        }
        finally
        {
            IsSubmitting = false;
        }
    }
}