@page "/admin/finance/reports"
@layout AdminLayout
@using SoccerPitchMvc.Models
@using SoccerPitchMvc.Services
@inject IFinanceService FinanceService
@inject ToastService Toast

<PageTitle>Báo cáo tài chính hợp nhất - Sổ quỹ</PageTitle>

<div class="page-header d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="page-title"><i class="fa-solid fa-chart-pie me-2 text-primary"></i>Báo cáo tài chính</h1>
        <p class="text-muted mb-0">Xem báo cáo tổng hợp dòng tiền từ tất cả các hoạt động đặt sân, bán lẻ, nhập hàng và chi phí vận hành</p>
    </div>
</div>

<!-- Date Range Filters -->
<div class="card shadow-sm border-0 mb-4">
    <div class="card-body p-3">
        <div class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label small fw-semibold">Từ ngày</label>
                <input type="date" class="form-control" @bind="StartDate" />
            </div>
            <div class="col-md-4">
                <label class="form-label small fw-semibold">Đến ngày</label>
                <input type="date" class="form-control" @bind="EndDate" />
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary w-100" @onclick="LoadReport">
                    <i class="fa-solid fa-filter me-1"></i>Lọc dữ liệu
                </button>
            </div>
            <div class="col-md-2">
                <button class="btn btn-outline-secondary w-100" @onclick="ResetFilters">
                    <i class="fa-solid fa-undo me-1"></i>Làm mới
                </button>
            </div>
        </div>
    </div>
</div>

@if (IsLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <div class="mt-2 text-muted">Đang tải báo cáo tổng hợp dòng tiền...</div>
    </div>
}
else
{
    <!-- KPI summary cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 bg-success bg-opacity-10 text-success">
                <div class="card-body py-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="fw-semibold text-uppercase small text-muted">Tổng thu dòng tiền</span>
                        <i class="fa-solid fa-arrow-trend-up fa-lg"></i>
                    </div>
                    <h2 class="fw-bold mb-0">@Summary.TotalRevenue.ToString("N0")đ</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 bg-danger bg-opacity-10 text-danger">
                <div class="card-body py-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="fw-semibold text-uppercase small text-muted">Tổng chi dòng tiền</span>
                        <i class="fa-solid fa-arrow-trend-down fa-lg"></i>
                    </div>
                    <h2 class="fw-bold mb-0">@Summary.TotalExpenses.ToString("N0")đ</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 @(Summary.NetIncome >= 0 ? "bg-primary bg-opacity-10 text-primary" : "bg-warning bg-opacity-10 text-warning")">
                <div class="card-body py-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="fw-semibold text-uppercase small text-muted">Thu nhập ròng (Lợi nhuận)</span>
                        <i class="fa-solid fa-scale-balanced fa-lg"></i>
                    </div>
                    <h2 class="fw-bold mb-0">@Summary.NetIncome.ToString("N0")đ</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 bg-dark bg-opacity-10 text-dark">
                <div class="card-body py-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="fw-semibold text-uppercase small text-muted">Số dư tồn quỹ còn lại</span>
                        <i class="fa-solid fa-wallet fa-lg"></i>
                    </div>
                    <h2 class="fw-bold mb-0 text-dark">@Summary.TotalBalance.ToString("N0")đ</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- Account Balances breakdown -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-0 py-3">
            <h5 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-vault me-2 text-info"></i>Số dư phân bổ quỹ tài khoản</h5>
        </div>
        <div class="card-body pt-0">
            <div class="row g-3 text-center">
                <div class="col-md-4">
                    <div class="border rounded p-3 bg-light">
                        <div class="text-muted small fw-semibold mb-1"><i class="fa-solid fa-money-bill-1 text-success me-1"></i>Két tiền mặt (Cash)</div>
                        <h3 class="fw-bold mb-0 text-dark">@Summary.CashBalance.ToString("N0")đ</h3>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="border rounded p-3 bg-light">
                        <div class="text-muted small fw-semibold mb-1"><i class="fa-solid fa-building-columns text-primary me-1"></i>Ngân hàng (Transfer)</div>
                        <h3 class="fw-bold mb-0 text-dark">@Summary.BankBalance.ToString("N0")đ</h3>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="border rounded p-3 bg-light">
                        <div class="text-muted small fw-semibold mb-1"><i class="fa-solid fa-mobile-screen text-info me-1"></i>Ví điện tử (Momo/Zalo)</div>
                        <h3 class="fw-bold mb-0 text-dark">@Summary.EWalletBalance.ToString("N0")đ</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Category Distribution Reports -->
    <div class="row g-4 mb-4">
        <!-- Income Categories -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3">
                    <h5 class="fw-bold mb-0 text-success"><i class="fa-solid fa-circle-arrow-down me-2"></i>Nguồn doanh thu (Income Sources)</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Nguồn thu</th>
                                    <th class="text-center" width="80">Số lượt</th>
                                    <th class="text-end" width="130">Số tiền thu</th>
                                    <th class="px-3" width="180">Tỷ trọng</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var cat in CategoryReports.Where(c => c.CategoryId < 20))
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@cat.CategoryName</div>
                                        </td>
                                        <td class="text-center">@cat.TransactionCount</td>
                                        <td class="text-end fw-bold text-success">@cat.TotalAmount.ToString("N0")đ</td>
                                        <td class="px-3">
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="progress flex-grow-1" style="height: 6px;">
                                                    <div class="progress-bar bg-success" role="progressbar" style="width: @(cat.Percentage)%;"></div>
                                                </div>
                                                <small class="text-muted" style="min-width: 35px;">@cat.Percentage.ToString("F1")%</small>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Expense Categories -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3">
                    <h5 class="fw-bold mb-0 text-danger"><i class="fa-solid fa-circle-arrow-up me-2"></i>Chi phí & Khoản chi (Expenses Breakdown)</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Mục chi</th>
                                    <th class="text-center" width="80">Số lượt</th>
                                    <th class="text-end" width="130">Số tiền chi</th>
                                    <th class="px-3" width="180">Tỷ trọng</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var cat in CategoryReports.Where(c => c.CategoryId >= 20))
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@cat.CategoryName</div>
                                        </td>
                                        <td class="text-center">@cat.TransactionCount</td>
                                        <td class="text-end fw-bold text-danger">@cat.TotalAmount.ToString("N0")đ</td>
                                        <td class="px-3">
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="progress flex-grow-1" style="height: 6px;">
                                                    <div class="progress-bar bg-danger" role="progressbar" style="width: @(cat.Percentage)%;"></div>
                                                </div>
                                                <small class="text-muted" style="min-width: 35px;">@cat.Percentage.ToString("F1")%</small>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .card-hover:hover {
        transform: translateY(-2px);
        transition: transform 0.2s ease-in-out;
    }
</style>

@code {
    private CashFlowSummaryDto Summary = new();
    private List<CategoryBreakdownDto> CategoryReports = new();
    private bool IsLoading = true;

    private DateTime? StartDate;
    private DateTime? EndDate;

    protected override async Task OnInitializedAsync()
    {
        await LoadReport();
    }

    private async Task LoadReport()
    {
        IsLoading = true;
        Summary = await FinanceService.GetCashFlowSummaryAsync(StartDate, EndDate);
        CategoryReports = await FinanceService.GetCategoryReportAsync(StartDate, EndDate);
        IsLoading = false;
    }

    private void ResetFilters()
    {
        StartDate = null;
        EndDate = null;
        _ = LoadReport();
    }
}