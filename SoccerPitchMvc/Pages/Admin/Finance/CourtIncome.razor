@page "/admin/finance/court-income"
@layout AdminLayout
@using SoccerPitchMvc.Models
@using SoccerPitchMvc.Services
@inject IFinanceService FinanceService
@inject ToastService Toast

<PageTitle>Doanh thu đặt sân - Tài chính</PageTitle>

<div class="page-header d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="page-title"><i class="fa-solid fa-money-bill-wave me-2 text-success"></i>Doanh thu đặt sân</h1>
        <p class="text-muted mb-0">Quản lý và thống kê chi tiết dòng tiền thu về từ các lượt đặt sân Pickleball đã thanh toán</p>
    </div>
</div>

<!-- Stats Row -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 card-hover">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-success bg-opacity-10 p-3">
                    <i class="fa-solid fa-coins fa-lg text-success"></i>
                </div>
                <div>
                    <div class="small text-muted fw-semibold">Tổng doanh thu đặt sân</div>
                    <div class="fs-3 fw-bold text-success">@TotalAmount.ToString("N0")đ</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 card-hover">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                    <i class="fa-solid fa-calendar-check fa-lg text-primary"></i>
                </div>
                <div>
                    <div class="small text-muted fw-semibold">Số lượt đặt sân đã trả</div>
                    <div class="fs-3 fw-bold text-primary">@Incomes.Count lượt</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 card-hover">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-info bg-opacity-10 p-3">
                    <i class="fa-solid fa-scale-balanced fa-lg text-info"></i>
                </div>
                <div>
                    <div class="small text-muted fw-semibold">Doanh thu trung bình/lượt</div>
                    <div class="fs-3 fw-bold text-info">@AverageAmount.ToString("N0")đ</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Filters -->
<div class="card shadow-sm border-0 mb-4">
    <div class="card-body p-3">
        <div class="row g-3 align-items-center">
            <div class="col-md-4">
                <label class="form-label small fw-semibold">Tìm kiếm</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0 text-muted"><i class="fas fa-search"></i></span>
                    <input type="text" class="form-control border-start-0" placeholder="Tên khách hàng, số điện thoại, sân..."
                           @bind-value="SearchText" @bind-value:event="oninput" />
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Từ ngày chơi</label>
                <input type="date" class="form-control" @bind="StartDate" />
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Đến ngày chơi</label>
                <input type="date" class="form-control" @bind="EndDate" />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button class="btn btn-outline-secondary w-100" @onclick="ResetFilters">
                    <i class="fas fa-undo me-1"></i>Làm mới
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Table -->
<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        @if (IsLoading)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-primary" role="status"></div>
                <div class="mt-2 text-muted">Đang tải báo cáo doanh thu sân...</div>
            </div>
        }
        else if (!FilteredList.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="fa-solid fa-money-bill-wave fa-3x text-light mb-3"></i>
                <p>Không tìm thấy bản ghi doanh thu đặt sân nào.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th width="40">#</th>
                            <th>Mã lượt đặt</th>
                            <th>Tên sân bóng</th>
                            <th>Khách hàng</th>
                            <th class="text-center">Ngày chơi</th>
                            <th class="text-center">Khung giờ</th>
                            <th class="text-end">Tiền sân thu</th>
                            <th class="text-center">Ngày thanh toán</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var (income, idx) in FilteredList.Select((inc, i) => (inc, i + 1)))
                        {
                            <tr>
                                <td class="text-muted fw-semibold small">@idx</td>
                                <td>
                                    <span class="fw-bold text-dark">#DS-@income.BookingId.ToString("D5")</span>
                                </td>
                                <td>
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25">
                                        <i class="fa-solid fa-table-tennis-paddle-ball me-1"></i>@income.PitchName
                                    </span>
                                </td>
                                <td>
                                    <div class="fw-bold">@income.CustomerName</div>
                                    <small class="text-muted"><i class="fa-solid fa-phone me-1 small"></i>@income.CustomerPhone</small>
                                </td>
                                <td class="text-center fw-semibold">@income.BookingDate.ToString("dd/MM/yyyy")</td>
                                <td class="text-center">
                                    <span class="badge bg-light text-dark border"><i class="fa-regular fa-clock me-1"></i>@income.TimeSlot</span>
                                </td>
                                <td class="text-end fw-bold text-success">@income.Amount.ToString("N0")đ</td>
                                <td class="text-center small text-muted">@income.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="card-footer bg-light text-muted small">
                Hiển thị <strong>@FilteredList.Count</strong> / @Incomes.Count lượt thanh toán đặt sân
            </div>
        }
    </div>
</div>

<style>
    .card-hover:hover {
        transform: translateY(-2px);
        transition: transform 0.2s ease-in-out;
    }
</style>

@code {
    private List<CourtIncomeDto> Incomes = new();
    private bool IsLoading = true;
    private string SearchText = string.Empty;
    private DateTime? StartDate;
    private DateTime? EndDate;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        IsLoading = true;
        Incomes = await FinanceService.GetCourtIncomeReportAsync();
        IsLoading = false;
    }

    private List<CourtIncomeDto> FilteredList
    {
        get
        {
            var q = Incomes.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(SearchText))
            {
                var txt = SearchText.Trim().ToLower();
                q = q.Where(x => x.CustomerName.ToLower().Contains(txt) 
                              || x.CustomerPhone.Contains(txt) 
                              || x.PitchName.ToLower().Contains(txt));
            }

            if (StartDate.HasValue)
            {
                var startOnly = DateOnly.FromDateTime(StartDate.Value);
                q = q.Where(x => x.BookingDate >= startOnly);
            }

            if (EndDate.HasValue)
            {
                var endOnly = DateOnly.FromDateTime(EndDate.Value);
                q = q.Where(x => x.BookingDate <= endOnly);
            }

            return q.ToList();
        }
    }

    private decimal TotalAmount => FilteredList.Sum(x => x.Amount);
    private decimal AverageAmount => FilteredList.Any() ? FilteredList.Average(x => x.Amount) : 0;

    private void ResetFilters()
    {
        SearchText = string.Empty;
        StartDate = null;
        EndDate = null;
    }
}