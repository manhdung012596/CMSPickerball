@page "/admin/bookings/calendar"
@layout AdminLayout
@inject SoccerPitchMvc.Services.IBookingService BookingService
@inject NavigationManager NavigationManager

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div>
            <h2 class="fw-bold text-dark mb-1"><i class="fa-solid fa-calendar text-success"></i> Lịch Đặt Sân</h2>
            <p class="text-muted">Xem nhanh tình trạng đặt sân của tất cả các sân Pickleball theo ngày</p>
        </div>
        <div class="d-flex align-items-center gap-3">
            <label class="fw-semibold text-dark mb-0">Chọn ngày:</label>
            <input type="date" class="form-control form-control-lg border-2 border-success shadow-sm" 
                   value="@selectedDate.ToString("yyyy-MM-dd")" @onchange="OnDateChanged" style="width: 200px;" />
        </div>
    </div>

    <!-- Status Legend -->
    <div class="card shadow-sm border-0 rounded-3 mb-4 bg-light">
        <div class="card-body py-3">
            <div class="d-flex flex-wrap gap-4 align-items-center justify-content-center text-dark fw-semibold">
                <div class="d-flex align-items-center gap-2">
                    <span class="d-inline-block rounded" style="width: 20px; height: 20px; background-color: #e8f5e9; border: 1px dashed #2e7d32;"></span>
                    <span>Còn trống (Bấm để đặt)</span>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <span class="d-inline-block rounded bg-warning" style="width: 20px; height: 20px;"></span>
                    <span>Chờ xác nhận</span>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <span class="d-inline-block rounded bg-primary text-white" style="width: 20px; height: 20px;"></span>
                    <span>Đã xác nhận</span>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <span class="d-inline-block rounded bg-success text-white" style="width: 20px; height: 20px;"></span>
                    <span>Đã thanh toán</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Calendar Matrix -->
    @if (pitches == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-success" role="status">
                <span class="visually-hidden">Đang tải...</span>
            </div>
        </div>
    }
    else if (!pitches.Any())
    {
        <div class="alert alert-warning text-center p-5 rounded-3">
            <i class="bi bi-exclamation-circle-fill display-4 d-block mb-3"></i>
            Chưa có sân Pickleball nào hoạt động để hiển thị lịch biểu.
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-4">
            @foreach (var pitch in pitches)
            {
                <div class="card shadow-sm border-0 rounded-3">
                    <div class="card-header bg-dark text-white py-3 d-flex justify-content-between align-items-center">
                        <h5 class="fw-bold mb-0"><i class="fa-solid fa-table-tennis-paddle-ball text-success me-2"></i> @pitch.Name</h5>
                        <span class="badge bg-success">130,000 VNĐ / giờ</span>
                    </div>
                    <div class="card-body p-4">
                        @if (pitchTimeSlots.TryGetValue(pitch.Id, out var slots) && slots.Any())
                        {
                            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-3">
                                @foreach (var slot in slots)
                                {
                                    var booking = FindBooking(pitch.Id, slot.Id);
                                    
                                    <div class="col">
                                        <div class="card h-100 border-0 shadow-sm @GetSlotCardClass(booking)" style="transition: all 0.2s;">
                                            <div class="card-body p-3 d-flex flex-column justify-content-between">
                                                <div>
                                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                                        <span class="fw-bold fs-5 text-dark">
                                                            <i class="bi bi-clock me-1 text-secondary"></i>
                                                            @FormatTime(slot.StartTime) - @FormatTime(slot.EndTime)
                                                        </span>
                                                        @if (slot.PriceOverride.HasValue)
                                                        {
                                                            <span class="badge bg-danger">@slot.PriceOverride.Value.ToString("N0") đ</span>
                                                        }
                                                    </div>
                                                    
                                                    @if (booking != null)
                                                    {
                                                        <div class="mt-2 text-dark">
                                                            <div class="fw-bold text-truncate" style="font-size: 0.95rem;">
                                                                <i class="bi bi-person-fill text-muted me-1"></i> @booking.Customer?.FullName
                                                            </div>
                                                            <div class="small text-muted text-truncate">
                                                                <i class="bi bi-telephone text-muted me-1"></i> @booking.Customer?.PhoneNumber
                                                            </div>
                                                            <div class="mt-2">
                                                                @((MarkupString)GetStatusBadge(booking.Status))
                                                            </div>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div class="text-success fw-semibold my-3 text-center">
                                                            <i class="bi bi-calendar-plus-fill me-1"></i> Sân đang trống
                                                        </div>
                                                    }
                                                </div>

                                                @if (booking == null)
                                                {
                                                    <button class="btn btn-sm btn-success w-100 mt-2 fw-semibold shadow-sm" 
                                                            @onclick="() => BookNow(pitch.Id, slot.Id)">
                                                        Đặt Ngay
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button class="btn btn-sm btn-outline-dark w-100 mt-2 fw-semibold" 
                                                            @onclick="() => ViewDetail(booking.Id)">
                                                        Chi tiết
                                                    </button>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-4 text-muted border rounded-3 bg-light">
                                <i class="bi bi-calendar-x d-block fs-3 mb-2 text-secondary"></i>
                                Chưa có khung giờ nào được thiết lập cho sân này. <a href="admin/pitches/timeslots" class="text-success fw-bold">Thiết lập ngay</a>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private DateOnly selectedDate = DateOnly.FromDateTime(DateTime.Today);
    private List<Pitch>? pitches;
    private List<Booking>? bookings;
    private Dictionary<int, List<TimeSlot>> pitchTimeSlots = new();

    protected override async Task OnInitializedAsync()
    {
        pitches = await BookingService.GetActivePitchesAsync();
        
        if (pitches != null)
        {
            foreach (var p in pitches)
            {
                var slots = await BookingService.GetTimeSlotsForPitchAsync(p.Id);
                pitchTimeSlots[p.Id] = slots;
            }
        }

        await LoadBookingsAsync();
    }

    private async Task LoadBookingsAsync()
    {
        bookings = await BookingService.GetBookingsByDateAsync(selectedDate);
    }

    private async Task OnDateChanged(ChangeEventArgs e)
    {
        string val = e.Value?.ToString() ?? "";
        if (DateTime.TryParse(val, out var dt))
        {
            selectedDate = DateOnly.FromDateTime(dt);
            await LoadBookingsAsync();
        }
    }

    private Booking? FindBooking(int pitchId, int timeSlotId)
    {
        if (bookings == null) return null;
        return bookings.FirstOrDefault(b => b.PitchId == pitchId && b.TimeSlotId == timeSlotId && b.Status != 3);
    }

    private string FormatTime(TimeOnly time)
    {
        return time.ToString(@"HH\:mm");
    }

    private string GetSlotCardClass(Booking? b)
    {
        if (b == null) return "bg-light border border-success-subtle hover-border";
        return b.Status switch
        {
            0 => "bg-warning-subtle border-start border-4 border-warning", // Pending
            1 => "bg-primary-subtle border-start border-4 border-primary", // Confirmed
            2 => "bg-success-subtle border-start border-4 border-success", // Paid
            _ => "bg-light border"
        };
    }

    private string GetStatusBadge(int status)
    {
        return status switch
        {
            0 => "<span class='badge bg-warning text-dark'><i class='bi bi-hourglass-split'></i> Chờ duyệt</span>",
            1 => "<span class='badge bg-primary text-white'><i class='bi bi-patch-check-fill'></i> Đã xác nhận</span>",
            2 => "<span class='badge bg-success text-white'><i class='bi bi-credit-card-fill'></i> Đã thanh toán</span>",
            _ => "<span class='badge bg-secondary text-white'>Không rõ</span>"
        };
    }

    private void BookNow(int pitchId, int slotId)
    {
        NavigationManager.NavigateTo($"admin/bookings/create?pitchId={pitchId}&timeSlotId={slotId}&date={selectedDate:yyyy-MM-dd}");
    }

    private void ViewDetail(int bookingId)
    {
        NavigationManager.NavigateTo("admin/bookings");
    }
}

<style>
    .hover-border:hover {
        border-color: #198754 !important;
        transform: translateY(-2px);
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        cursor: pointer;
    }
</style>