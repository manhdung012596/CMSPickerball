@page "/admin/shop/orders/create"
@layout AdminLayout
@using SoccerPitchMvc.Models
@using SoccerPitchMvc.Services
@inject IShopService ShopService
@inject ICustomerService CustomerService
@inject IPromotionService PromotionService
@inject IMasterdataService MasterService
@inject ToastService Toast
@inject NavigationManager NavigationManager

<PageTitle>Tạo đơn hàng mới - Shop</PageTitle>

<div class="row g-4 h-100 POS-layout" style="min-height: calc(100vh - 120px);">
    <!-- Left Column: Product Selection (7/12) -->
    <div class="col-lg-7 d-flex flex-column">
        <!-- POS Header & Search -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h4 class="fw-bold mb-0 text-dark">
                        <i class="fa-solid fa-cart-plus text-primary me-2"></i>Màn hình bán hàng (POS)
                    </h4>
                    <a href="/admin/shop/orders" class="btn btn-sm btn-outline-secondary">
                        <i class="fa-solid fa-list-check me-1"></i>Xem danh sách đơn
                    </a>
                </div>
                <div class="row g-2">
                    <div class="col-md-8">
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0 text-muted"><i class="fas fa-search"></i></span>
                            <input type="text" class="form-control border-start-0" placeholder="Tìm sản phẩm theo tên hoặc SKU..."
                                   @bind-value="SearchText" @bind-value:event="oninput" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <select class="form-select" @bind="FilterCategory">
                            <option value="0">Tất cả danh mục</option>
                            @foreach (var cat in Categories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <!-- Products Grid Scroll Container -->
        <div class="flex-grow-1" style="overflow-y: auto; max-height: calc(100vh - 270px);">
            @if (IsProductsLoading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <div class="mt-2 text-muted">Đang tải sản phẩm...</div>
                </div>
            }
            else if (!FilteredProducts.Any())
            {
                <div class="card border-0 shadow-sm text-center p-5">
                    <i class="fa-solid fa-box-open fa-3x text-muted mb-3"></i>
                    <p class="text-muted">Không tìm thấy sản phẩm nào trong kho.</p>
                </div>
            }
            else
            {
                <div class="row row-cols-2 row-cols-md-3 g-3">
                    @foreach (var prod in FilteredProducts)
                    {
                        <div class="col">
                            <div class="card border-0 shadow-sm h-100 product-card @(prod.StockQuantity <= 0 ? "out-of-stock" : "")"
                                 @onclick="() => AddToCart(prod)">
                                <div class="position-relative">
                                    <div class="product-badge position-absolute top-0 start-0 m-2">
                                        <span class="badge @prod.StockStatusBadge">
                                            @prod.StockQuantity @prod.UnitSymbol
                                        </span>
                                    </div>
                                    <div class="product-card-img-container bg-light d-flex align-items-center justify-content-center">
                                        @if (!string.IsNullOrEmpty(prod.ImageUrl))
                                        {
                                            <img src="@prod.ImageUrl" alt="@prod.Name" class="product-card-img"
                                                 onerror="this.src='/images/products/placeholder.png'; this.onerror=null;" />
                                        }
                                        else
                                        {
                                            <i class="fa-solid fa-box-open fa-2x text-muted"></i>
                                        }
                                    </div>
                                </div>
                                <div class="card-body p-2 d-flex flex-column justify-content-between">
                                    <div>
                                        <div class="small text-muted font-monospace text-uppercase">@prod.SKU</div>
                                        <div class="fw-bold product-card-title text-dark">@prod.Name</div>
                                    </div>
                                    <div class="d-flex align-items-center justify-content-between mt-2">
                                        <span class="fw-bold text-success">@prod.SellingPrice.ToString("N0")đ</span>
                                        @if (prod.StockQuantity > 0)
                                        {
                                            <button class="btn btn-sm btn-primary rounded-circle p-1 d-flex align-items-center justify-content-center" style="width: 26px; height: 26px;">
                                                <i class="fa-solid fa-plus small"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="text-danger small fw-semibold">Hết hàng</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Right Column: Checkout & Cart Details (5/12) -->
    <div class="col-lg-5 d-flex flex-column h-100">
        <div class="card border-0 shadow-sm d-flex flex-column h-100" style="max-height: calc(100vh - 120px);">
            <!-- Customer Selector -->
            <div class="card-header bg-white border-bottom p-3">
                <label class="form-label fw-bold text-muted small text-uppercase mb-1"><i class="fa-solid fa-user me-1"></i>Khách hàng</label>
                <div class="row g-2">
                    <div class="col-md-9">
                        <select class="form-select" @bind="SelectedCustomerId">
                            <option value="0">Khách vãng lai</option>
                            @foreach (var cust in Customers)
                            {
                                <option value="@cust.Id">@cust.FullName - @cust.PhoneNumber</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <button class="btn btn-outline-danger w-100" @onclick="ResetCustomer" title="Bỏ chọn">
                            <i class="fa-solid fa-user-slash"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Cart Items List (Scrollable) -->
            <div class="card-body p-3 flex-grow-1" style="overflow-y: auto;">
                <label class="form-label fw-bold text-muted small text-uppercase mb-2"><i class="fa-solid fa-basket-shopping me-1"></i>Giỏ hàng</label>
                
                @if (!Cart.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <i class="fa-solid fa-shopping-basket fa-3x mb-3 text-light"></i>
                        <p class="mb-0">Giỏ hàng đang trống.</p>
                        <small>Click chọn sản phẩm ở bên trái để mua.</small>
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var item in Cart)
                        {
                            <div class="list-group-item px-0 py-2 border-bottom d-flex align-items-center justify-content-between">
                                <div style="flex: 1;" class="pe-2">
                                    <div class="fw-semibold text-dark small text-truncate" style="max-width: 220px;" title="@item.ProductName">@item.ProductName</div>
                                    <span class="text-muted small">@item.Price.ToString("N0")đ</span>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <!-- Qty Control -->
                                    <div class="input-group input-group-sm" style="width: 100px;">
                                        <button class="btn btn-outline-secondary" type="button" @onclick="() => DecreaseQty(item)">
                                            <i class="fa-solid fa-minus"></i>
                                        </button>
                                        <input type="text" class="form-control text-center px-1" value="@item.Quantity" readonly />
                                        <button class="btn btn-outline-secondary" type="button" @onclick="() => IncreaseQty(item)">
                                            <i class="fa-solid fa-plus"></i>
                                        </button>
                                    </div>
                                    <span class="fw-bold text-end ms-2" style="width: 85px;">@item.TotalPrice.ToString("N0")đ</span>
                                    <button class="btn btn-sm btn-link text-danger p-0 ms-1" @onclick="() => RemoveFromCart(item)">
                                        <i class="fa-solid fa-trash-can"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- Promotion Coupon Section -->
            <div class="p-3 bg-light border-top border-bottom">
                <label class="form-label fw-bold text-muted small text-uppercase mb-1"><i class="fa-solid fa-ticket-simple me-1"></i>Mã giảm giá</label>
                <div class="input-group input-group-sm">
                    <input type="text" class="form-control font-monospace text-uppercase" placeholder="Nhập mã giảm giá..."
                           @bind="CouponCode" disabled="@IsCouponApplied" />
                    @if (IsCouponApplied)
                    {
                        <button class="btn btn-danger" type="button" @onclick="RemoveCoupon">
                            <i class="fa-solid fa-xmark me-1"></i>Hủy
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-primary" type="button" @onclick="ApplyCoupon" disabled="@(!Cart.Any())">
                            Áp dụng
                        </button>
                    }
                </div>
                @if (!string.IsNullOrEmpty(CouponMessage))
                {
                    <div class="small mt-1 @(IsCouponApplied ? "text-success" : "text-danger")">
                        <i class="fa-solid @(IsCouponApplied ? "fa-circle-check" : "fa-circle-xmark") me-1"></i>@CouponMessage
                    </div>
                }
            </div>

            <!-- Financial calculations -->
            <div class="card-footer bg-white p-3 border-0 shadow-sm mt-auto">
                <div class="d-flex justify-content-between mb-1 text-muted">
                    <span>Tổng tiền hàng:</span>
                    <span>@CartTotal.ToString("N0")đ</span>
                </div>
                <div class="d-flex justify-content-between mb-1 text-success">
                    <span>Giảm giá:</span>
                    <span>-@DiscountAmount.ToString("N0")đ</span>
                </div>
                <hr class="my-2" />
                <div class="d-flex justify-content-between mb-3">
                    <span class="fw-bold text-dark fs-5">Khách phải trả:</span>
                    <span class="fw-bold text-danger fs-4">@FinalTotal.ToString("N0")đ</span>
                </div>

                <!-- Payment details -->
                <div class="row g-2 mb-3">
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Hình thức thanh toán</label>
                        <select class="form-select form-select-sm" @bind="PaymentMethod">
                            <option value="0">Tiền mặt</option>
                            <option value="1">Chuyển khoản</option>
                            <option value="2">Ví điện tử</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Tiền khách đưa</label>
                        <div class="input-group input-group-sm">
                            <input type="number" class="form-control text-end text-success fw-bold" @bind="CustomerCash" @bind:event="oninput" />
                            <span class="input-group-text">đ</span>
                        </div>
                    </div>
                </div>

                @if (CustomerCash > 0 && CustomerCash >= FinalTotal)
                {
                    <div class="alert alert-success py-2 mb-3 d-flex justify-content-between align-items-center">
                        <span class="small"><i class="fa-solid fa-hand-holding-dollar me-1"></i>Tiền thừa trả khách:</span>
                        <strong class="fs-5">@RefundAmount.ToString("N0")đ</strong>
                    </div>
                }

                <div class="mb-3">
                    <input type="text" class="form-control form-control-sm" placeholder="Ghi chú đơn hàng..." @bind="Notes" />
                </div>

                <!-- Action Button -->
                <button class="btn btn-primary w-100 py-2 fs-5" @onclick="SubmitOrder" disabled="@(!Cart.Any() || IsSubmitting)">
                    @if (IsSubmitting)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    }
                    <i class="fa-solid fa-circle-check me-2"></i>Thanh toán & Hoàn thành
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .product-card {
        cursor: pointer;
        transition: all 0.2s ease;
        border: 1px solid #e9ecef;
    }
    .product-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.08)!important;
        border-color: var(--bs-primary);
    }
    .product-card-img-container {
        height: 120px;
        overflow: hidden;
    }
    .product-card-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .product-card-title {
        font-size: 0.9rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        height: 2.7rem;
        line-height: 1.35;
        margin-top: 2px;
    }
    .product-card.out-of-stock {
        opacity: 0.6;
        cursor: not-allowed;
    }
    .product-badge {
        z-index: 2;
    }
    .fs-7 {
        font-size: 0.8rem;
    }
</style>

@code {
    private List<ProductListDto> Products = new();
    private List<ProductCategoryListDto> Categories = new();
    private List<CustomerListDto> Customers = new();

    private bool IsProductsLoading = true;
    private string SearchText = string.Empty;
    private int FilterCategory = 0;

    // POS Cart State
    private List<CartItem> Cart = new();
    private int SelectedCustomerId = 0;
    private int PaymentMethod = 0;
    private decimal CustomerCash = 0;
    private string Notes = string.Empty;
    
    // Coupon State
    private string CouponCode = string.Empty;
    private bool IsCouponApplied = false;
    private string CouponMessage = string.Empty;
    private decimal DiscountAmount = 0;

    private bool IsSubmitting = false;

    // Helper Cart Item representation
    public class CartItem
    {
        public int ProductId { get; set; }
        public string ProductName { get; set; } = string.Empty;
        public decimal Price { get; set; }
        public int Quantity { get; set; }
        public int MaxQuantity { get; set; }
        public decimal TotalPrice => Price * Quantity;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
        Categories = await MasterService.GetAllProductCategoriesAsync();
        Customers = await CustomerService.GetCustomersAsync();
    }

    private async Task LoadProducts()
    {
        IsProductsLoading = true;
        // Load only active/selling products
        Products = await ShopService.GetProductsAsync(status: 1);
        IsProductsLoading = false;
    }

    private List<ProductListDto> FilteredProducts
    {
        get
        {
            var q = Products.AsEnumerable();
            if (!string.IsNullOrWhiteSpace(SearchText))
            {
                var txt = SearchText.Trim().ToLower();
                q = q.Where(p => p.Name.ToLower().Contains(txt) || (p.SKU != null && p.SKU.ToLower().Contains(txt)));
            }
            if (FilterCategory > 0)
            {
                q = q.Where(p => p.CategoryId == FilterCategory);
            }
            return q.ToList();
        }
    }

    private void AddToCart(ProductListDto prod)
    {
        if (prod.StockQuantity <= 0)
        {
            Toast.ShowError($"Sản phẩm «{prod.Name}» đã hết hàng.");
            return;
        }

        var existing = Cart.FirstOrDefault(x => x.ProductId == prod.Id);
        if (existing != null)
        {
            if (existing.Quantity >= prod.StockQuantity)
            {
                Toast.ShowError($"Không thể thêm. Chỉ có {prod.StockQuantity} sản phẩm trong kho.");
                return;
            }
            existing.Quantity++;
        }
        else
        {
            Cart.Add(new CartItem
            {
                ProductId = prod.Id,
                ProductName = prod.Name,
                Price = prod.SellingPrice,
                Quantity = 1,
                MaxQuantity = prod.StockQuantity
            });
        }
        
        // Recalculate coupon if applied
        if (IsCouponApplied)
        {
            _ = ApplyCoupon();
        }
    }

    private void IncreaseQty(CartItem item)
    {
        if (item.Quantity >= item.MaxQuantity)
        {
            Toast.ShowError($"Chỉ có tối đa {item.MaxQuantity} sản phẩm trong kho.");
            return;
        }
        item.Quantity++;
        if (IsCouponApplied) _ = ApplyCoupon();
    }

    private void DecreaseQty(CartItem item)
    {
        if (item.Quantity > 1)
        {
            item.Quantity--;
            if (IsCouponApplied) _ = ApplyCoupon();
        }
        else
        {
            Cart.Remove(item);
            if (IsCouponApplied) _ = ApplyCoupon();
        }
    }

    private void RemoveFromCart(CartItem item)
    {
        Cart.Remove(item);
        if (IsCouponApplied) _ = ApplyCoupon();
    }

    private void ResetCustomer()
    {
        SelectedCustomerId = 0;
    }

    private decimal CartTotal => Cart.Sum(x => x.TotalPrice);
    private decimal FinalTotal => Math.Max(0, CartTotal - DiscountAmount);
    private decimal RefundAmount => Math.Max(0, CustomerCash - FinalTotal);

    private async Task ApplyCoupon()
    {
        if (string.IsNullOrWhiteSpace(CouponCode)) return;
        var code = CouponCode.Trim().ToUpper();

        var (isValid, message, discount) = await PromotionService.ValidateCouponAsync(code, CartTotal);
        if (isValid)
        {
            DiscountAmount = discount;
            IsCouponApplied = true;
            CouponMessage = $"Áp dụng thành công! Giảm {discount.ToString("N0")}đ.";
        }
        else
        {
            DiscountAmount = 0;
            IsCouponApplied = false;
            CouponMessage = message;
        }
    }

    private void RemoveCoupon()
    {
        CouponCode = string.Empty;
        IsCouponApplied = false;
        DiscountAmount = 0;
        CouponMessage = string.Empty;
    }

    private async Task SubmitOrder()
    {
        if (!Cart.Any()) return;

        IsSubmitting = true;
        try
        {
            var customer = Customers.FirstOrDefault(c => c.Id == SelectedCustomerId);
            
            var dto = new CreateOrderDto
            {
                CustomerId = SelectedCustomerId > 0 ? SelectedCustomerId : null,
                CustomerName = SelectedCustomerId > 0 ? customer?.FullName : "Khách vãng lai",
                CustomerPhone = SelectedCustomerId > 0 ? customer?.PhoneNumber : null,
                DiscountAmount = DiscountAmount,
                CouponCode = IsCouponApplied ? CouponCode.Trim().ToUpper() : null,
                PaymentMethod = PaymentMethod,
                PaymentStatus = 1, // Auto-marked as Paid for POS
                OrderStatus = 1, // Completed
                Notes = Notes,
                OrderItems = Cart.Select(x => new CreateOrderItemDto
                {
                    ProductId = x.ProductId,
                    Quantity = x.Quantity,
                    Price = x.Price
                }).ToList()
            };

            await ShopService.CreateOrderAsync(dto);
            Toast.ShowSuccess("Tạo đơn hàng và thanh toán thành công!");
            NavigationManager.NavigateTo("/admin/shop/orders");
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Thanh toán thất bại: {ex.Message}");
        }
        finally
        {
            IsSubmitting = false;
        }
    }
}