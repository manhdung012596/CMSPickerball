@page "/admin/shop/orders"
@layout AdminLayout
@using SoccerPitchMvc.Models
@using SoccerPitchMvc.Services
@inject IShopService ShopService
@inject ToastService Toast
@inject NavigationManager NavigationManager

<PageTitle>Danh sách đơn hàng - Shop</PageTitle>

<div class="page-header d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="page-title"><i class="fa-solid fa-clipboard-list me-2 text-primary"></i>Danh sách Đơn hàng</h1>
        <p class="text-muted mb-0">Tra cứu hóa đơn, doanh thu bán hàng và cập nhật trạng thái đơn hàng của shop</p>
    </div>
    <a href="/admin/shop/orders/create" class="btn btn-primary px-3">
        <i class="fa-solid fa-cart-plus me-1"></i> Đơn hàng mới (POS)
    </a>
</div>

<!-- Stats row -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100 card-hover">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-success bg-opacity-10 p-3">
                    <i class="fa-solid fa-money-bill-wave fa-lg text-success"></i>
                </div>
                <div>
                    <div class="small text-muted fw-semibold">Tổng doanh thu shop</div>
                    <div class="fs-3 fw-bold text-success">@Stats.TotalRevenue.ToString("N0")đ</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100 card-hover">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                    <i class="fa-solid fa-file-invoice-dollar fa-lg text-primary"></i>
                </div>
                <div>
                    <div class="small text-muted fw-semibold">Tổng số đơn hàng</div>
                    <div class="fs-3 fw-bold text-primary">@Stats.TotalOrdersCount đơn</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100 card-hover">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-info bg-opacity-10 p-3">
                    <i class="fa-solid fa-chart-line fa-lg text-info"></i>
                </div>
                <div>
                    <div class="small text-muted fw-semibold">Lợi nhuận ước tính</div>
                    <div class="fs-3 fw-bold text-info">@Stats.TotalProfit.ToString("N0")đ</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100 card-hover">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-warning bg-opacity-10 p-3">
                    <i class="fa-solid fa-clock-rotate-left fa-lg text-warning"></i>
                </div>
                <div>
                    <div class="small text-muted fw-semibold">Số đơn hàng chờ</div>
                    <div class="fs-3 fw-bold text-warning">@Orders.Count(o => o.OrderStatus == 0) đơn</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Filters -->
<div class="card shadow-sm border-0 mb-4">
    <div class="card-body p-3">
        <div class="row g-3">
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Tìm kiếm</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0 text-muted"><i class="fas fa-search"></i></span>
                    <input type="text" class="form-control border-start-0" placeholder="Mã đơn, tên, sđt khách..."
                           @bind-value="SearchText" @bind-value:event="oninput" />
                </div>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold">Từ ngày</label>
                <input type="date" class="form-control" @bind="StartDate" />
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold">Đến ngày</label>
                <input type="date" class="form-control" @bind="EndDate" />
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold">Trạng thái đơn</label>
                <select class="form-select" @bind="FilterOrderStatus">
                    <option value="-1">Tất cả</option>
                    <option value="0">Chờ xử lý</option>
                    <option value="1">Hoàn thành</option>
                    <option value="2">Đã hủy</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold">Thanh toán</label>
                <select class="form-select" @bind="FilterPaymentStatus">
                    <option value="-1">Tất cả</option>
                    <option value="1">Đã thanh toán</option>
                    <option value="0">Chưa thanh toán</option>
                </select>
            </div>
            <div class="col-md-1 d-flex align-items-end">
                <button class="btn btn-outline-secondary w-100" @onclick="ResetFilters" title="Làm mới bộ lọc">
                    <i class="fas fa-undo"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Orders Table -->
<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        @if (IsLoading)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-primary" role="status"></div>
                <div class="mt-2 text-muted">Đang tải danh sách đơn hàng...</div>
            </div>
        }
        else if (!FilteredList.Any())
        {
            <div class="text-center py-5">
                <i class="fa-solid fa-receipt fa-3x text-muted mb-3 d-block"></i>
                <p class="text-muted">Không tìm thấy hóa đơn nào phù hợp.</p>
                <a href="/admin/shop/orders/create" class="btn btn-primary">
                    <i class="fa-solid fa-cart-plus me-1"></i>Tạo đơn hàng đầu tiên
                </a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th width="40">#</th>
                            <th>Mã đơn hàng</th>
                            <th>Khách hàng</th>
                            <th class="text-center">Ngày tạo</th>
                            <th class="text-end">Tiền hàng</th>
                            <th class="text-end">Giảm giá</th>
                            <th class="text-end">Tổng cộng</th>
                            <th class="text-center">Thanh toán</th>
                            <th class="text-center">Trạng thái</th>
                            <th width="140" class="text-center">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var (order, idx) in FilteredList.Select((o, i) => (o, i + 1)))
                        {
                            <tr>
                                <td class="text-muted fw-semibold small">@idx</td>
                                <td>
                                    <span class="fw-bold text-primary">@order.OrderCode</span>
                                    @if (!string.IsNullOrEmpty(order.Notes))
                                    {
                                        <div class="text-muted small text-truncate" style="max-width: 150px;" title="@order.Notes">
                                            <i class="fa-regular fa-comment-dots text-warning me-1"></i>@order.Notes
                                        </div>
                                    }
                                </td>
                                <td>
                                    @if (order.CustomerId.HasValue)
                                    {
                                        <div class="fw-semibold text-dark">@order.CustomerName</div>
                                        <small class="text-muted"><i class="fa-solid fa-phone me-1 small"></i>@order.CustomerPhone</small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">@order.CustomerName</span>
                                    }
                                </td>
                                <td class="text-center small">@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-end text-muted">@order.TotalAmount.ToString("N0")đ</td>
                                <td class="text-end text-success">-@order.DiscountAmount.ToString("N0")đ</td>
                                <td class="text-end fw-bold text-danger">@order.FinalAmount.ToString("N0")đ</td>
                                <td class="text-center">
                                    <span class="badge @order.PaymentStatusBadge">@order.PaymentStatusText</span>
                                </td>
                                <td class="text-center">
                                    <span class="badge @order.OrderStatusBadge">@order.OrderStatusText</span>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm">
                                        <button class="btn btn-outline-info" title="Xem chi tiết"
                                                @onclick="() => OpenDetailsModal(order.Id)">
                                            <i class="fa-solid fa-eye"></i>
                                        </button>
                                        @if (order.OrderStatus != 2)
                                        {
                                            <button class="btn btn-outline-warning" title="Hủy đơn hàng"
                                                    @onclick="() => CancelOrder(order.Id)">
                                                <i class="fa-solid fa-ban"></i>
                                            </button>
                                        }
                                        <button class="btn btn-outline-danger" title="Xóa"
                                                @onclick="() => ConfirmDelete(order)">
                                            <i class="fa-solid fa-trash-can"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="card-footer bg-light text-muted small">
                Hiển thị <strong>@FilteredList.Count</strong> / @Orders.Count hóa đơn
            </div>
        }
    </div>
</div>

<!-- Details Modal -->
@if (ShowDetailsModal && SelectedOrder != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        <i class="fa-solid fa-file-invoice me-2"></i>Chi tiết đơn hàng @SelectedOrder.OrderCode
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseDetailsModal"></button>
                </div>
                <div class="modal-body py-4">
                    <!-- Invoice Info -->
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label class="text-muted small text-uppercase fw-semibold d-block">Thông tin hóa đơn</label>
                            <div class="mt-1">
                                <strong>Mã hóa đơn:</strong> <span class="text-primary fw-bold">@SelectedOrder.OrderCode</span>
                            </div>
                            <div>
                                <strong>Ngày tạo:</strong> @SelectedOrder.OrderDate.ToString("dd/MM/yyyy HH:mm")
                            </div>
                            <div>
                                <strong>Trạng thái đơn:</strong> 
                                <span class="badge @(SelectedOrder.OrderStatus == 1 ? "bg-success" : (SelectedOrder.OrderStatus == 2 ? "bg-danger" : "bg-warning text-dark"))">
                                    @(SelectedOrder.OrderStatus == 1 ? "Hoàn thành" : (SelectedOrder.OrderStatus == 2 ? "Đã hủy" : "Chờ xử lý"))
                                </span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small text-uppercase fw-semibold d-block">Khách hàng & Thanh toán</label>
                            <div class="mt-1">
                                <strong>Khách hàng:</strong> @(SelectedOrder.CustomerName ?? "Khách vãng lai")
                            </div>
                            @if (!string.IsNullOrEmpty(SelectedOrder.CustomerPhone))
                            {
                                <div>
                                    <strong>Số điện thoại:</strong> @SelectedOrder.CustomerPhone
                                </div>
                            }
                            <div>
                                <strong>Thanh toán:</strong>
                                <span class="badge @(SelectedOrder.PaymentStatus == 1 ? "bg-success" : "bg-warning text-dark")">
                                    @(SelectedOrder.PaymentStatus == 1 ? "Đã thanh toán" : "Chưa thanh toán")
                                </span>
                                <span class="text-muted small ms-1">(@(SelectedOrder.PaymentMethod == 0 ? "Tiền mặt" : (SelectedOrder.PaymentMethod == 1 ? "Chuyển khoản" : "Ví điện tử")))</span>
                            </div>
                        </div>
                    </div>

                    <!-- Items Table -->
                    <label class="text-muted small text-uppercase fw-semibold mb-2 d-block">Danh sách sản phẩm mua</label>
                    <div class="table-responsive border rounded mb-3">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th width="40">#</th>
                                    <th>Tên sản phẩm</th>
                                    <th class="text-end" width="120">Đơn giá</th>
                                    <th class="text-center" width="100">Số lượng</th>
                                    <th class="text-end" width="150">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var (item, idx) in SelectedOrder.OrderItems.Select((o, i) => (o, i + 1)))
                                {
                                    <tr>
                                        <td class="text-muted small">@idx</td>
                                        <td class="fw-bold">@item.ProductName</td>
                                        <td class="text-end">@item.Price.ToString("N0")đ</td>
                                        <td class="text-center">@item.Quantity</td>
                                        <td class="text-end fw-semibold">@item.TotalPrice.ToString("N0")đ</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- Totals summary -->
                    <div class="row justify-content-end">
                        <div class="col-md-5">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-muted">Tổng cộng:</span>
                                <span>@SelectedOrder.TotalAmount.ToString("N0")đ</span>
                            </div>
                            <div class="d-flex justify-content-between mb-1 text-success">
                                <span>Giảm giá:</span>
                                <span>-@SelectedOrder.DiscountAmount.ToString("N0")đ</span>
                            </div>
                            <hr class="my-2" />
                            <div class="d-flex justify-content-between mb-1">
                                <strong class="text-dark">Thực thanh toán:</strong>
                                <strong class="text-danger fs-5">@SelectedOrder.FinalAmount.ToString("N0")đ</strong>
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(SelectedOrder.Notes))
                    {
                        <div class="alert alert-warning py-2 mb-0 mt-3 small">
                            <i class="fa-regular fa-comment-dots me-1"></i>
                            <strong>Ghi chú:</strong> @SelectedOrder.Notes
                        </div>
                    }
                </div>
                <div class="modal-footer bg-light">
                    @if (SelectedOrder.OrderStatus == 0)
                    {
                        <button class="btn btn-success me-auto" @onclick="CompleteOrder">
                            <i class="fa-solid fa-circle-check me-1"></i>Hoàn thành đơn hàng
                        </button>
                    }
                    <button class="btn btn-outline-secondary" @onclick="CloseDetailsModal">Đóng lại</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Delete Confirmation Modal -->
@if (ShowDeleteModal && OrderToDelete != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">
                        <i class="fas fa-exclamation-triangle me-2"></i>Xác nhận xóa hóa đơn
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => ShowDeleteModal = false"></button>
                </div>
                <div class="modal-body py-3">
                    <p>Bạn có chắc chắn muốn xóa hóa đơn:</p>
                    <p class="fw-bold text-danger fs-5 mb-1">@OrderToDelete.OrderCode</p>
                    <p class="text-muted">Tổng tiền: <strong class="text-dark">@OrderToDelete.FinalAmount.ToString("N0")đ</strong></p>
                    <div class="alert alert-warning mt-3 mb-0 py-2 small">
                        <i class="fa-solid fa-triangle-exclamation me-1"></i>
                        <strong>Lưu ý:</strong> Nếu hóa đơn đang ở trạng thái <strong>Hoàn thành</strong>, hệ thống sẽ tự động <strong>hoàn lại tồn kho</strong> cho các sản phẩm trong đơn hàng khi xóa hóa đơn này.
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" @onclick="() => ShowDeleteModal = false">Hủy</button>
                    <button class="btn btn-danger" @onclick="ExecuteDelete" disabled="@IsDeleting">
                        @if (IsDeleting) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <i class="fas fa-trash me-1"></i>Xác nhận xóa
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .card-hover:hover {
        transform: translateY(-2px);
        transition: transform 0.2s ease-in-out;
    }
</style>

@code {
    private List<OrderListDto> Orders = new();
    private ShopStatsDto Stats = new();

    private bool IsLoading = true;
    private string SearchText = string.Empty;
    private int FilterOrderStatus = -1;
    private int FilterPaymentStatus = -1;
    private DateTime? StartDate;
    private DateTime? EndDate;

    // Details Modal
    private bool ShowDetailsModal = false;
    private Order? SelectedOrder;

    // Delete Modal
    private bool ShowDeleteModal = false;
    private bool IsDeleting = false;
    private OrderListDto? OrderToDelete;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        IsLoading = true;
        Orders = await ShopService.GetOrdersAsync();
        Stats = await ShopService.GetShopStatsAsync();
        IsLoading = false;
    }

    private List<OrderListDto> FilteredList
    {
        get
        {
            var q = Orders.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(SearchText))
            {
                var txt = SearchText.Trim().ToLower();
                q = q.Where(o => o.OrderCode.ToLower().Contains(txt) 
                              || (o.CustomerName != null && o.CustomerName.ToLower().Contains(txt))
                              || (o.CustomerPhone != null && o.CustomerPhone.Contains(txt)));
            }

            if (StartDate.HasValue)
            {
                q = q.Where(o => o.OrderDate >= StartDate.Value.Date);
            }

            if (EndDate.HasValue)
            {
                q = q.Where(o => o.OrderDate <= EndDate.Value.Date.AddDays(1).AddTicks(-1));
            }

            if (FilterOrderStatus != -1)
            {
                q = q.Where(o => o.OrderStatus == FilterOrderStatus);
            }

            if (FilterPaymentStatus != -1)
            {
                q = q.Where(o => o.PaymentStatus == FilterPaymentStatus);
            }

            return q.ToList();
        }
    }

    private void ResetFilters()
    {
        SearchText = string.Empty;
        StartDate = null;
        EndDate = null;
        FilterOrderStatus = -1;
        FilterPaymentStatus = -1;
    }

    private async Task OpenDetailsModal(int id)
    {
        SelectedOrder = await ShopService.GetOrderByIdAsync(id);
        if (SelectedOrder != null)
        {
            ShowDetailsModal = true;
        }
        else
        {
            Toast.ShowError("Không tìm thấy thông tin đơn hàng.");
        }
    }

    private void CloseDetailsModal()
    {
        ShowDetailsModal = false;
        SelectedOrder = null;
    }

    private async Task CompleteOrder()
    {
        if (SelectedOrder == null) return;
        
        try
        {
            // Update to Completed (1) and Paid (1)
            bool ok = await ShopService.UpdateOrderStatusAsync(SelectedOrder.Id, 1, 1);
            if (ok)
            {
                Toast.ShowSuccess("Cập nhật hoàn thành đơn hàng thành công!");
                CloseDetailsModal();
                await LoadData();
            }
            else
            {
                Toast.ShowError("Không thể cập nhật trạng thái đơn.");
            }
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Lỗi: {ex.Message}");
        }
    }

    private async Task CancelOrder(int id)
    {
        try
        {
            // Cancelled (2), Payment stays same or pending
            bool ok = await ShopService.UpdateOrderStatusAsync(id, 2, 0);
            if (ok)
            {
                Toast.ShowSuccess("Đã hủy đơn hàng và hoàn lại tồn kho thành công!");
                await LoadData();
            }
            else
            {
                Toast.ShowError("Không thể hủy đơn hàng.");
            }
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Lỗi khi hủy đơn: {ex.Message}");
        }
    }

    private void ConfirmDelete(OrderListDto order)
    {
        OrderToDelete = order;
        ShowDeleteModal = true;
    }

    private async Task ExecuteDelete()
    {
        if (OrderToDelete == null) return;

        IsDeleting = true;
        try
        {
            bool success = await ShopService.DeleteOrderAsync(OrderToDelete.Id);
            if (success)
            {
                Toast.ShowSuccess($"Đã xóa hóa đơn «{OrderToDelete.OrderCode}» thành công.");
                await LoadData();
            }
            else
            {
                Toast.ShowError("Không thể xóa hóa đơn.");
            }
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Lỗi: {ex.Message}");
        }
        finally
        {
            IsDeleting = false;
            ShowDeleteModal = false;
            OrderToDelete = null;
        }
    }
}