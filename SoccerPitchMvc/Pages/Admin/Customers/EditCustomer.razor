@page "/admin/customers/edit/{customerId:int}"
@layout AdminLayout
@inject SoccerPitchMvc.Services.ICustomerService CustomerService
@inject SoccerPitchMvc.Services.ToastService ToastService
@inject NavigationManager NavigationManager

<div class="container-fluid mt-4" style="max-width: 700px;">
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-primary text-white py-3">
            <h4 class="fw-bold mb-0"><i class="bi bi-pencil-square"></i> Chỉnh Sửa Thông Tin Khách Hàng</h4>
        </div>
        <div class="card-body p-4">
            @if (customerToUpdate == null)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Đang tải...</span>
                    </div>
                </div>
            }
            else
            {
                <EditForm Model="@customerToUpdate" OnValidSubmit="HandleSubmit">
                    <DataAnnotationsValidator />
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold text-dark">Họ và Tên <span class="text-danger">*</span></label>
                        <input type="text" class="form-control form-control-lg" @bind-value="customerToUpdate.FullName" placeholder="Nhập họ và tên..." />
                        <div class="text-danger small mt-1">
                            <ValidationMessage For="@(() => customerToUpdate.FullName)" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-dark">Số Điện Thoại <span class="text-danger">*</span></label>
                        <input type="tel" class="form-control form-control-lg" @bind-value="customerToUpdate.PhoneNumber" placeholder="Nhập số điện thoại..." />
                        <div class="text-danger small mt-1">
                            <ValidationMessage For="@(() => customerToUpdate.PhoneNumber)" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold text-dark">Địa Chỉ</label>
                        <textarea class="form-control" rows="3" @bind="customerToUpdate.Address" placeholder="Nhập địa chỉ (tùy chọn)..."></textarea>
                        <div class="text-danger small mt-1">
                            <ValidationMessage For="@(() => customerToUpdate.Address)" />
                        </div>
                    </div>

                    <div class="d-flex gap-3 justify-content-end">
                        <button type="button" class="btn btn-lg btn-outline-secondary px-4" @onclick="BackToList">
                            Quay lại
                        </button>
                        <button type="submit" class="btn btn-lg btn-primary px-5 fw-semibold shadow-sm">
                            Cập nhật
                        </button>
                    </div>
                </EditForm>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int customerId { get; set; }

    private UpdateCustomerDto? customerToUpdate;

    protected override async Task OnInitializedAsync()
    {
        customerToUpdate = await CustomerService.GetCustomerByIdForEditAsync(customerId);
        if (customerToUpdate == null)
        {
            ToastService.ShowError("Khách hàng không tồn tại hoặc đã bị xóa.");
            NavigationManager.NavigateTo("admin/customers");
        }
    }

    private async Task HandleSubmit()
    {
        if (customerToUpdate == null) return;

        var success = await CustomerService.UpdateCustomerAsync(customerToUpdate);
        if (success)
        {
            ToastService.ShowSuccess($"Đã cập nhật thành công thông tin khách hàng '{customerToUpdate.FullName}'.");
            NavigationManager.NavigateTo("admin/customers");
        }
        else
        {
            ToastService.ShowError("Số điện thoại này đã được sử dụng bởi khách hàng khác.");
        }
    }

    private void BackToList()
    {
        NavigationManager.NavigateTo("admin/customers");
    }
}
