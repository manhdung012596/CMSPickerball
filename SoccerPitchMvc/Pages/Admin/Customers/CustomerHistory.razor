@page "/admin/customers/history/{customerId:int}"
@layout AdminLayout
@inject SoccerPitchMvc.Services.ICustomerService CustomerService
@inject NavigationManager NavigationManager

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div>
            <h2 class="fw-bold text-dark mb-1"><i class="fa-solid fa-clock-rotate-left text-success"></i> Lịch sử đặt sân</h2>
            @if (customer != null)
            {
                <p class="text-muted">Lịch sử đặt sân Pickleball của khách hàng: <strong class="text-dark">@customer.FullName</strong> (@customer.PhoneNumber)</p>
            }
            else
            {
                <p class="text-muted">Lịch sử đặt sân của khách hàng</p>
            }
        </div>
        <button class="btn btn-outline-secondary shadow-sm" @onclick="BackToList">
            <i class="bi bi-arrow-left"></i> Quay lại
        </button>
    </div>

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="py-3 px-4">Sân</th>
                            <th class="py-3">Ngày đặt</th>
                            <th class="py-3">Khung giờ</th>
                            <th class="py-3">Trạng thái</th>
                            <th class="py-3 text-end px-4">Tổng tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (customerBookings == null)
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <div class="spinner-border text-success" role="status">
                                        <span class="visually-hidden">Đang tải...</span>
                                    </div>
                                </td>
                            </tr>
                        }
                        else if (!customerBookings.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    Khách hàng này chưa thực hiện lượt đặt sân nào.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var b in customerBookings)
                            {
                                <tr>
                                    <td class="fw-bold text-dark py-3 px-4">@b.Pitch?.Name</td>
                                    <td class="text-dark">@b.BookingDate.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <span class="badge bg-secondary fs-6">
                                            @FormatTime(b.TimeSlot?.StartTime) - @FormatTime(b.TimeSlot?.EndTime)
                                        </span>
                                    </td>
                                    <td>
                                        @((MarkupString)GetStatusBadge(b.Status))
                                    </td>
                                    <td class="text-end px-4 fw-bold text-success">
                                        @b.TotalPrice.ToString("N0") VNĐ
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int customerId { get; set; }

    private UpdateCustomerDto? customer;
    private List<Booking>? customerBookings;

    protected override async Task OnInitializedAsync()
    {
        customer = await CustomerService.GetCustomerByIdForEditAsync(customerId);
        if (customer != null)
        {
            customerBookings = await CustomerService.GetCustomerBookingsAsync(customerId);
        }
    }

    private void BackToList()
    {
        NavigationManager.NavigateTo("admin/customers");
    }

    private string FormatTime(TimeOnly? time)
    {
        if (!time.HasValue) return "";
        return time.Value.ToString(@"HH\:mm");
    }

    private string GetStatusBadge(int status)
    {
        return status switch
        {
            0 => "<span class='badge bg-warning text-dark'><i class='bi bi-hourglass-split'></i> Chờ duyệt</span>",
            1 => "<span class='badge bg-primary text-white'><i class='bi bi-patch-check-fill'></i> Đã xác nhận</span>",
            2 => "<span class='badge bg-success text-white'><i class='bi bi-credit-card-fill'></i> Đã thanh toán</span>",
            3 => "<span class='badge bg-danger text-white'><i class='bi bi-x-circle-fill'></i> Đã hủy</span>",
            _ => "<span class='badge bg-secondary text-white'>Không rõ</span>"
        };
    }
}